---
import GalleryItem from './GalleryItem.astro';
import { works } from '../data/works';
const latestWorks = works.slice(0, 4);
---

<section id="works" class="works-section container">
  <div class="section-header-row">
    <div class="header-left">
      <div class="section-num">02</div>
      <h2>LATEST WORKS</h2>
    </div>
    <a href="/works" class="view-all-works">VIEW ALL WORKS &rarr;</a>
  </div>

  <div class="filter-row">
    <button class="filter-item active">ALL</button>
    <button class="filter-item">NOVEL</button>
    <button class="filter-item">PUISI</button>
    <button class="filter-item">CERPEN</button>
    <button class="filter-item">ESAI</button>
    <button class="filter-item">DESAIN</button>
    <button class="filter-item">CATATAN</button>
  </div>

  <div class="gallery-grid-new">
    {latestWorks.map((work) => (
      <GalleryItem {...work} />
    ))}
  </div>
</section>

<style>
  .works-section {
    padding: 100px 0;
    border-top: 1px solid var(--glass-border);
  }

  .section-header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 50px;
  }

  .header-left h2 {
    font-size: 2.2rem;
  }

  .view-all-works {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    opacity: 0.6;
  }

  .filter-row {
    display: flex;
    gap: 30px;
    margin-bottom: 50px;
    border-bottom: 1px solid var(--glass-border);
    padding-bottom: 20px;
  }

  .filter-item {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    opacity: 0.4;
    transition: opacity 0.3s;
  }

  .filter-item.active, .filter-item:hover {
    opacity: 1;
    color: var(--accent-color);
  }

  .gallery-grid-new {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .grid-controls {
    display: flex;
    justify-content: flex-end;
    gap: 15px;
  }

  .grid-ctrl-btn {
    width: 45px;
    height: 45px;
    border: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
  }
</style>
