---
import GalleryItem from './GalleryItem.astro';
import { db } from '../db';
import { works as worksTable, categories as categoryTable } from '../db/schema';
import { desc, eq } from 'drizzle-orm';

// 1. Fetch Categories for Filters
const dbCategories = await db.select().from(categoryTable);

// 2. Fetch Latest 6 Published Works with Category Names
const latestWorks = await db
  .select({
    id: worksTable.id,
    title: worksTable.title,
    cover: worksTable.cover,
    type: worksTable.type,
    status: worksTable.status,
    category: categoryTable.name,
    createdAt: worksTable.createdAt,
  })
  .from(worksTable)
  .leftJoin(categoryTable, eq(worksTable.categoryId, categoryTable.id))
  .where(eq(worksTable.status, 'published'))
  .orderBy(desc(worksTable.createdAt))
  .limit(6);
---

<section id="works" class="py-[120px] max-lg:py-[60px] border-t border-glass-border container">
  <header class="text-center mb-20">
    <div class="flex items-center gap-[15px] justify-center text-[0.9rem] font-medium mb-5">02 / LATEST</div>
    <h2 class="text-[3.5rem] max-lg:text-[2.2rem] mb-[15px]">LATEST WORKS</h2>
    <p class="text-[0.8rem] tracking-[0.2em] uppercase opacity-60">Recently unearthed from the archives.</p>
  </header>

  <!-- Desktop Filter Row -->
  <div class="hidden lg:flex justify-center gap-[25px] mb-[50px] border-bottom border-glass-border pb-[15px]">
    <button class="filter-item text-[0.65rem] tracking-[0.1em] opacity-40 transition-all duration-300 hover:opacity-100 hover:text-accent active:opacity-100 active:text-accent [&.active]:opacity-100 [&.active]:text-accent" data-category="ALL">
      <span>ALL</span>
    </button>
    {dbCategories.map(cat => (
      <button class="filter-item text-[0.65rem] tracking-[0.1em] opacity-40 transition-all duration-300 hover:opacity-100 hover:text-accent [&.active]:opacity-100 [&.active]:text-accent" data-category={cat.name.toUpperCase()}>
        <span>{cat.name.toUpperCase()}</span>
      </button>
    ))}
  </div>

  <!-- Mobile Floating Filter -->
  <div class="lg:hidden mb-10 relative text-center">
    <button id="mobile-filter-trigger" class="inline-flex items-center gap-2.5 bg-white/3 border border-glass-border px-[18px] py-2.5 text-white text-[0.6rem] tracking-[0.15em] font-bold">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[13px] h-[13px] text-accent"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
      <span>FILTER ARCHIVE</span>
    </button>
    
    <div 
      id="mobile-filter-menu" 
      class="absolute top-[calc(100%+10px)] left-0 w-full bg-[#0f0f0ff2] backdrop-blur-[20px] border border-glass-border z-[500] p-5 opacity-0 invisible translate-y-2.5 transition-all duration-400 cubic-bezier-[0.165,0.84,0.44,1] [&.open]:opacity-100 [&.open]:visible [&.open]:translate-y-0"
    >
      <div class="flex justify-between items-center mb-5 pb-2.5 border-b border-white/5">
        <span class="text-[0.6rem] tracking-[0.2em] opacity-50 font-extrabold uppercase">SELECT CATEGORY</span>
        <button id="close-filter" class="text-2xl leading-none opacity-50">&times;</button>
      </div>
      <div class="grid grid-cols-2 gap-2.5">
        <button class="mobile-opt p-[15px] bg-white/2 border border-white/5 text-[0.65rem] tracking-[0.1em] text-center transition-all duration-300 [&.active]:bg-accent [&.active]:text-black [&.active]:border-accent [&.active]:font-extrabold" data-category="ALL">ALL</button>
        {dbCategories.map(cat => (
          <button class="mobile-opt p-[15px] bg-white/2 border border-white/5 text-[0.65rem] tracking-[0.1em] text-center transition-all duration-300 [&.active]:bg-accent [&.active]:text-black [&.active]:border-accent [&.active]:font-extrabold" data-category={cat.name.toUpperCase()}>{cat.name.toUpperCase()}</button>
        ))}
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-[15px] lg:gap-[30px] mb-[60px]">
    {latestWorks.map((work) => (
      <GalleryItem 
        id={work.id.toString()} 
        title={work.title} 
        category={work.category || 'Uncategorized'} 
        cover={work.cover || "https://via.placeholder.com/600x800"}
        date={new Date(work.createdAt).getFullYear().toString()}
      />
    ))}
    {latestWorks.length === 0 && (
      <p class="col-span-full text-center opacity-50 py-[50px]">No works published yet.</p>
    )}
  </div>


  <div class="mt-[60px] flex justify-center">
    <a href="/works" class="inline-block px-10 py-[15px] border border-glass-border text-[0.75rem] tracking-[0.2em] font-bold transition-all duration-400 hover:bg-accent hover:text-black hover:border-accent hover:-translate-y-0.5 no-underline">VIEW ALL WORKS</a>
  </div>
</section>

<script>
  function initFloatingFilter() {
    const trigger = document.getElementById('mobile-filter-trigger');
    const menu = document.getElementById('mobile-filter-menu');
    const closeBtn = document.getElementById('close-filter');
    const opts = document.querySelectorAll('.mobile-opt');
    const desktopBtns = document.querySelectorAll('.filter-item');
    const galleryItems = document.querySelectorAll('.gallery-item-new');

    function applyFilter(cat: string) {
      const lowerCat = cat.toLowerCase();
      
      // Update UI (Desktop & Mobile)
      [...opts, ...desktopBtns].forEach(btn => {
        if ((btn as HTMLElement).dataset.category === cat) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Filter Gallery
      galleryItems.forEach(item => {
        const itemCat = (item as HTMLElement).dataset.category;
        if (lowerCat === 'all' || itemCat === lowerCat) {
          (item as HTMLElement).style.display = 'block';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    }

    trigger?.addEventListener('click', () => menu?.classList.add('open'));
    closeBtn?.addEventListener('click', () => menu?.classList.remove('open'));

    opts.forEach(opt => {
      opt.addEventListener('click', () => {
        const cat = (opt as HTMLElement).dataset.category || 'ALL';
        applyFilter(cat);
        menu?.classList.remove('open');
      });
    });

    desktopBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = (btn as HTMLElement).dataset.category || 'ALL';
        applyFilter(cat);
      });
    });
  }

  initFloatingFilter();
</script>
