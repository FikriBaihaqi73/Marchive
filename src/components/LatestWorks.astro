---
import GalleryItem from './GalleryItem.astro';
import { db } from '../db';
import { works as worksTable, categories as categoryTable } from '../db/schema';
import { desc, eq } from 'drizzle-orm';

// 1. Fetch Categories for Filters
const dbCategories = await db.select().from(categoryTable);

// 2. Fetch Latest 6 Published Works with Category Names
const latestWorks = await db
  .select({
    id: worksTable.id,
    title: worksTable.title,
    cover: worksTable.cover,
    type: worksTable.type,
    status: worksTable.status,
    category: categoryTable.name,
    createdAt: worksTable.createdAt,
  })
  .from(worksTable)
  .leftJoin(categoryTable, eq(worksTable.categoryId, categoryTable.id))
  .where(eq(worksTable.status, 'published'))
  .orderBy(desc(worksTable.createdAt))
  .limit(6);
---

<section id="works" class="works-section container">
  <header class="section-header">
    <div class="section-num">02 / LATEST</div>
    <h2>LATEST WORKS</h2>
    <p class="subtitle text-muted">Recently unearthed from the archives.</p>
  </header>

  <!-- Desktop Filter Row -->
  <div class="filter-row-desktop">
    <button class="filter-item active" data-category="ALL">
      <span>ALL</span>
    </button>
    {dbCategories.map(cat => (
      <button class="filter-item" data-category={cat.name.toUpperCase()}>
        <span>{cat.name.toUpperCase()}</span>
      </button>
    ))}
  </div>

  <!-- Mobile Floating Filter -->
  <div class="mobile-filter-wrapper">
    <button id="mobile-filter-trigger" class="filter-trigger">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
      <span>FILTER ARCHIVE</span>
    </button>
    
    <div id="mobile-filter-menu" class="floating-filter-menu">
      <div class="menu-header">
        <span>SELECT CATEGORY</span>
        <button id="close-filter">&times;</button>
      </div>
      <div class="filter-options">
        <button class="mobile-opt active" data-category="ALL">ALL</button>
        {dbCategories.map(cat => (
          <button class="mobile-opt" data-category={cat.name.toUpperCase()}>{cat.name.toUpperCase()}</button>
        ))}
      </div>
    </div>
  </div>

  <div class="gallery-grid-new">
    {latestWorks.map((work) => (
      <GalleryItem 
        id={work.id.toString()} 
        title={work.title} 
        category={work.category || 'Uncategorized'} 
        cover={work.cover || "https://via.placeholder.com/600x800"}
        date={new Date(work.createdAt).getFullYear().toString()}
      />
    ))}
    {latestWorks.length === 0 && (
      <p style="grid-column: 1/-1; text-align: center; opacity: 0.5; padding: 50px;">No works published yet.</p>
    )}
  </div>


  <div class="works-footer">
    <a href="/works" class="btn-outline">VIEW ALL WORKS</a>
  </div>
</section>

<style>
  @import "../styles/latest-works.css";
</style>

<script>
  function initFloatingFilter() {
    const trigger = document.getElementById('mobile-filter-trigger');
    const menu = document.getElementById('mobile-filter-menu');
    const closeBtn = document.getElementById('close-filter');
    const opts = document.querySelectorAll('.mobile-opt');
    const desktopBtns = document.querySelectorAll('.filter-item');
    const galleryItems = document.querySelectorAll('.gallery-item-new');

    function applyFilter(cat: string) {
      const lowerCat = cat.toLowerCase();
      
      // Update UI (Desktop & Mobile)
      [...opts, ...desktopBtns].forEach(btn => {
        if ((btn as HTMLElement).dataset.category === cat) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Filter Gallery
      galleryItems.forEach(item => {
        const itemCat = (item as HTMLElement).dataset.category;
        if (lowerCat === 'all' || itemCat === lowerCat) {
          (item as HTMLElement).style.display = 'block';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    }

    trigger?.addEventListener('click', () => menu?.classList.add('open'));
    closeBtn?.addEventListener('click', () => menu?.classList.remove('open'));

    opts.forEach(opt => {
      opt.addEventListener('click', () => {
        const cat = (opt as HTMLElement).dataset.category || 'ALL';
        applyFilter(cat);
        menu?.classList.remove('open');
      });
    });

    desktopBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = (btn as HTMLElement).dataset.category || 'ALL';
        applyFilter(cat);
      });
    });
  }

  initFloatingFilter();
</script>
