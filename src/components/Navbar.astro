---
const { pathname } = Astro.url;
const isActive = (path: string) => pathname === path || (path !== '/' && pathname.startsWith(path));
---

<nav class="absolute top-0 left-0 w-full z-100 py-10">
  <div class="container flex justify-between items-center">
    <a href="/" class="text-[1.4rem] font-medium text-accent font-serif tracking-[0.1em] no-underline">MARCHIVE</a>
    
    <div 
      id="nav-links"
      class="nav-links"
    >
      {[
        { href: '/', label: 'HOME' },
        { href: '/works', label: 'WORKS' },
        { href: '/categories', label: 'CATEGORIES' },
        { href: '/about', label: 'ABOUT' },
      ].map((link, i) => (
        <a 
          href={link.href} 
          class={`nav-item ${isActive(link.href) ? 'active' : ''}`}
          style={`transition-delay: ${0.2 + i * 0.1}s`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <button 
      class="menu-toggle relative z-[1000] p-2.5 bg-none border-none text-white cursor-pointer lg:hidden group" 
      id="menu-toggle" 
      aria-label="Toggle Menu"
    >
      <span class="block w-[25px] h-0.5 bg-current my-1.25 transition-all duration-300 group-[.open]:bg-accent group-[.open]:rotate-45 group-[.open]:translate-x-[5px] group-[.open]:translate-y-[5px]"></span>
      <span class="block w-[25px] h-0.5 bg-current my-1.25 transition-all duration-300 group-[.open]:opacity-0 group-[.open]:scale-x-0"></span>
      <span class="block w-[25px] h-0.5 bg-current my-1.25 transition-all duration-300 group-[.open]:bg-accent group-[.open]:-rotate-45 group-[.open]:translate-x-[5px] group-[.open]:-translate-y-[5px]"></span>
    </button>
  </div>
</nav>

<style is:global>
  @reference "../styles/global.css";

  .nav-links {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(30px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 40px;
    z-index: 998;
    opacity: 0;
    visibility: hidden;
    transform: translateX(100%);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .nav-links.open {
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
    pointer-events: auto;
  }

  .nav-item {
    font-size: 2rem;
    font-family: var(--font-serif);
    color: white;
    text-decoration: none;
    letter-spacing: 0.1em;
    opacity: 0;
    transform: translateY(30px);
    transition: transform 0.5s, opacity 0.5s;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-links.open .nav-item {
    opacity: 0.5;
    transform: translateY(0);
  }

  .nav-links.open .nav-item:hover,
  .nav-links.open .nav-item.active {
    opacity: 1;
    color: var(--accent-color);
  }

  @media (min-width: 1024px) {
    .nav-links {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: auto;
      height: auto;
      background: transparent;
      backdrop-filter: none;
      flex-direction: row;
      gap: 30px;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      z-index: auto;
    }

    .nav-item {
      font-size: 0.75rem;
      font-family: var(--font-sans);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      opacity: 0.5;
      transform: none;
      transition: all 0.3s ease;
    }

    .nav-item:hover, .nav-item.active {
      opacity: 1;
      color: var(--accent-color);
    }
  }
</style>

<script src="../scripts/navbar.ts"></script>

