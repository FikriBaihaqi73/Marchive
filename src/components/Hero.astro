---
import { db } from '@db/index';
import { works as worksTable, categories as categoryTable } from '../db/schema';
import { desc, eq } from 'drizzle-orm';

// Fetch Latest 5 Published Works for Hero Slider (Joined with Categories)
const featuredWorks = await db
  .select({
    id: worksTable.id,
    title: worksTable.title,
    cover: worksTable.cover,
    categoryName: categoryTable.name,
    type: worksTable.type,
    status: worksTable.status,
    createdAt: worksTable.createdAt,
  })
  .from(worksTable)
  .leftJoin(categoryTable, eq(worksTable.categoryId, categoryTable.id))
  .where(eq(worksTable.status, 'published'))
  .orderBy(desc(worksTable.createdAt))
  .limit(5);
---



<section class="hero-hybrid container">
  <div class="hero-grid">
    
    <!-- Static Part: Left Side -->
    <div class="hero-static">
      <div class="section-num">01</div>
      <h1 class="fade-in">MARCHIVE</h1>
      <p class="fade-in subtitle">A collection of thoughts, stories, and creations.</p>
    </div>

    <!-- Sliding Part: Right Side -->
    <div class="hero-slider-side">
      <div class="slides-inner" id="hero-slides">
        {featuredWorks.length === 0 && (
          <div class="hero-slide active">
            <div class="slide-content-wrap">
              <div class="image-box" style="background: rgba(255,255,255,0.02); display: flex; align-items: center; justify-content: center;">
                <span style="opacity: 0.2; font-size: 0.8rem; letter-spacing: 0.5em;">NO ENTRIES YET</span>
              </div>
              <div class="slide-caption">
                <p class="slide-cat">SYSTEM</p>
                <h3>Welcome to Marchive</h3>
              </div>
            </div>
          </div>
        )}
        {featuredWorks.map((work, index) => (
          <div class={`hero-slide ${index === 0 ? 'active' : ''}`} data-index={index}>
            <div class="slide-content-wrap">
              <a href={`/works/${work.id}`} class="image-link-wrap">
                <div class="image-box">
                  <img src={work.cover || "https://via.placeholder.com/600x800"} alt={work.title} />
                </div>
              </a>

              <div class="slide-caption">
                <!-- Progress Indicators - Right above the category -->
                <div class="slide-progress">
                  {featuredWorks.map((_, i) => (
                    <span class={`dot-line ${i === index ? 'active' : ''}`} data-index={i}></span>
                  ))}
                </div>
                <span class="cat">{work.categoryName || 'UNCATEGORIZED'}</span>
                <h2 class="work-title">{work.title}</h2>
              </div>
            </div>
          </div>
        ))}

        {/* Persistent Arrow Navigation */}
        <div class="slider-controls-ui">
          <div class="arrows-wrap">
            <button id="prev-hero" class="nav-btn-new" aria-label="Previous">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button id="next-hero" class="nav-btn-new" aria-label="Next">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @import "../styles/hero.css";
</style>

<script src="../scripts/hero-slider.ts"></script>
