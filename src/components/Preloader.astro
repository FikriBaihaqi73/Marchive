---
import { tapes } from '../data/preloader';

const REPEAT_COUNT = 15;
---

<div id="preloader" class="fixed top-0 left-0 w-full h-full bg-black z-[10000] overflow-hidden flex items-center justify-center [&.completed]:bg-transparent [&.completed]:pointer-events-none [&.completed]:transition-colors [&.completed]:duration-500" style="display: none;">
  {/* Inline Script Cepat untuk mencegah kilatan pita */}
  <script is:inline>
    (function() {
      if (!sessionStorage.getItem('marchive_visited')) {
        document.getElementById('preloader').style.display = 'flex';
      }
    })();
  </script>

  <div class="relative w-full h-full flex items-center justify-center" id="tapes-container">
    {tapes.map((tape, index) => (
      <div 
        class={`tape tape-item absolute -left-[100vw] text-black flex items-center overflow-hidden font-black text-base tracking-[0.1em] shadow-[0_0_40px_rgba(0,0,0,0.8)] whitespace-nowrap border-t-2 border-b-2 border-black/10 pointer-events-none`} 
        data-index={index}
        style={`
          top: ${tape.top}; 
          transform: rotate(${tape.rotate}); 
          background: ${tape.color || 'var(--accent-color)'};
          z-index: ${5 + index};
          opacity: ${tape.opacity || 1};
          height: ${tape.height || '50px'};
          width: ${tape.width || '400vw'};
        `}
      >
        <div class={`flex w-max ${tape.reverse ? 'animate-scroll-text-reverse' : 'animate-scroll-text'}`} style={`animation-duration: ${tape.speed}`}>
          <span>{tape.text.repeat(REPEAT_COUNT)}</span>
          <span>{tape.text.repeat(REPEAT_COUNT)}</span>
        </div>
      </div>
    ))}
    
    <div class="z-[1000] text-center relative">
      <div id="loading-box" class="bg-black/85 p-[30px_60px] max-md:p-[20px_30px] max-md:w-[280px] backdrop-blur-[10px] border border-accent/30 transition-all duration-500 [&.fade-out]:opacity-0 [&.fade-out]:scale-75 [&.fade-out]:pointer-events-none">
        <div class="w-[200px] h-[0.5px] bg-white/10 mx-auto mb-5 overflow-hidden">
          <div class="w-0 h-full bg-accent animate-load-progress"></div>
        </div>
        <h2 class="text-white text-[0.7rem] tracking-[0.6em] opacity-60 m-0">INITIALIZING ARCHIVE...</h2>
      </div>

      <button id="enter-btn" class="bg-accent text-black border-none p-[25px_60px] max-md:p-[20px_40px] cursor-pointer absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center gap-[5px] shadow-[0_0_50px_rgba(197,160,89,0.4)] transition-all duration-500 cubic-bezier-[0.175,0.885,0.32,1.275] whitespace-nowrap opacity-100 scale-100 [&.hidden]:opacity-0 [&.hidden]:scale-50 [&.hidden]:pointer-events-none hover:scale-105 hover:bg-white hover:shadow-[0_0_70_rgba(255,255,255,0.6)]">
        <span class="text-[1.2rem] font-black tracking-[0.2em]">ENTER ARCHIVE</span>
        <span class="text-[0.6rem] tracking-[0.1em] opacity-70 font-bold">Click to break the barrier</span>
      </button>
    </div>
  </div>
</div>

<style is:global>
  @reference "../styles/global.css";

  .tape-item.snapped {
    @apply transition-all duration-800 ease-[cubic-bezier(0.68,-0.55,0.27,1.55)] !opacity-0;
  }
  .tape-item.snapped[data-index="0"] { @apply !-translate-x-[100vw] !-translate-y-[100vh] !-rotate-45; }
  .tape-item.snapped[data-index="1"] { @apply !translate-x-[100vw] !-translate-y-[50vh] !rotate-45; }
  .tape-item.snapped[data-index="2"] { @apply !-translate-x-[100vw] !translate-y-[50vh] !-rotate-60; }
  .tape-item.snapped[data-index="3"] { @apply !translate-x-[100vw] !translate-y-[100vh] !rotate-30; }
  .tape-item.snapped[data-index="4"] { @apply !-translate-x-[120vw] !rotate-[-10deg]; }
  .tape-item.snapped[data-index="5"] { @apply !translate-x-[120vw] !translate-y-[20vh] !rotate-[20deg]; }
  .tape-item.snapped[data-index="6"] { @apply !-translate-y-[150vh] !rotate-90; }
  .tape-item.snapped[data-index="7"] { @apply !translate-y-[150vh] !-rotate-90; }
</style>

<script src="../scripts/preloader.ts"></script>
