---
interface Props {
  id: string;
  title: string;
  category: string;
  cover: string;
  date?: string;
  metadata?: string;
}

const { id, title, category, cover, date = '2024', metadata = '' } = Astro.props;
---

<a 
  href={`/works/${id}`}
  class="gallery-item-new fade-in" 
  data-category={category.toLowerCase()}
>
  <div class="card-inner">
    <div class="image-box">
      <img src={cover} alt={title} loading="lazy" />
    </div>
    <div class="content-box">
      <div class="main-info">
        <h3>{title}</h3>
        <p class="type">{category}</p>
      </div>
      <div class="footer-info">
        <span class="date">{date}</span>
      </div>
    </div>
  </div>
</a>

<style>
  @import "../styles/gallery-item.css";
</style>
