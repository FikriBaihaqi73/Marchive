---
interface Props {
  placeholder?: string;
  initialValue?: string;
}

const { placeholder = "Mulai menulis keajaiban...", initialValue = "" } = Astro.props;
---

<div class="rich-editor-wrapper">
  <div id="rich-editor" set:html={initialValue}></div>
</div>

<!-- Quill Library -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script is:inline src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

<script is:inline>
  // 1. Register Fonts
  var Font = Quill.import('formats/font');
  Font.whitelist = ['outfit', 'playfair', 'serif', 'monospace'];
  Quill.register(Font, true);

  // 2. FORCE Inline Styles for Size
  var SizeStyle = Quill.import('attributors/style/size');
  SizeStyle.whitelist = null; 
  Quill.register(SizeStyle, true);

  // 3. Initialize Quill
  var quill = new Quill('#rich-editor', {
    theme: 'snow',
    placeholder: 'Mulai menulis keajaiban...',
    modules: {
      toolbar: {
        container: [
          [{ 'font': ['outfit', 'playfair', 'serif', 'monospace'] }],
          ['custom-size'],
          ['bold', 'italic', 'underline', 'strike'],
          [{ 'align': [] }],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          ['clean']
        ],
        handlers: { 'custom-size': function() {} }
      }
    }
  });

  // 4. Safe Injection for Manual Size Input
  function setupManualSize() {
    const sizePlaceholder = document.querySelector('.ql-custom-size');
    if (!sizePlaceholder) return;

    sizePlaceholder.innerHTML = `
      <div class="custom-size-wrapper">
        <input type="number" id="manual-size-input" value="16" min="1" max="200" />
        <span class="px-label">px</span>
      </div>
    `;

    const sizeInput = document.getElementById('manual-size-input');

    sizeInput.addEventListener('change', (e) => {
      const val = e.target.value;
      if (val && val > 0) {
        quill.format('size', val + 'px');
      }
    });

    sizeInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const val = sizeInput.value;
        if (val && val > 0) {
          quill.format('size', val + 'px');
        }
        e.preventDefault();
        quill.focus();
      }
    });

    sizeInput.addEventListener('mousedown', (e) => e.stopPropagation());
    sizeInput.addEventListener('click', (e) => e.stopPropagation());

    quill.on('text-change', () => {
      const range = quill.getSelection();
      if (range && range.length === 0) {
        const val = sizeInput.value;
        if (val && val > 0) {
          quill.format('size', val + 'px');
        }
      }
    });

    quill.on('selection-change', (range) => {
      if (range) {
        if (range.length > 0) {
          const format = quill.getFormat(range);
          if (format.size) {
            sizeInput.value = format.size.replace('px', '');
          }
        } else {
          const val = sizeInput.value;
          if (val && val > 0) {
            quill.format('size', val + 'px');
          }
        }
      }
    });
  }

  setTimeout(setupManualSize, 100);
</script>

<style is:global>
  @reference "../../styles/global.css";

  .rich-editor-wrapper {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    overflow: hidden;
  }

  /* Toolbar Styling */
  .ql-toolbar.ql-snow {
    background: rgba(255, 255, 255, 0.05) !important;
    border: none !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08) !important;
    padding: 12px 20px !important;
  }

  @media (max-width: 768px) {
    .ql-toolbar.ql-snow {
      padding: 10px 10px !important;
    }
    .ql-editor {
      padding: 20px !important;
    }
  }

  .ql-snow .ql-stroke {
    stroke: rgba(255, 255, 255, 0.5) !important;
  }
  .ql-snow .ql-fill {
    fill: rgba(255, 255, 255, 0.5) !important;
  }
  .ql-snow .ql-picker {
    color: rgba(255, 255, 255, 0.5) !important;
  }

  .ql-snow.ql-toolbar button:hover .ql-stroke,
  .ql-snow.ql-toolbar button.ql-active .ql-stroke {
    stroke: var(--color-accent) !important;
  }
  
  .ql-snow.ql-toolbar button:hover .ql-fill,
  .ql-snow.ql-toolbar button.ql-active .ql-fill {
    fill: var(--color-accent) !important;
  }

  .ql-snow.ql-toolbar .ql-picker-label:hover,
  .ql-snow.ql-toolbar .ql-picker-label.ql-active {
    color: var(--color-accent) !important;
  }

  /* Custom Font Size Input */
  .ql-custom-size {
    width: auto !important;
    padding: 0 10px !important;
  }

  .custom-size-wrapper {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.2);
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    height: 26px;
  }

  #manual-size-input {
    background: transparent;
    border: none;
    color: #ffffff; /* Pure White for maximum visibility */
    width: 32px;
    font-size: 0.9rem;
    font-weight: 800;
    text-align: center;
    padding: 0;
    outline: none;
    line-height: 1;
    -moz-appearance: textfield;
  }

  #manual-size-input::-webkit-outer-spin-button,
  #manual-size-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .px-label {
    font-size: 0.65rem;
    color: #c5a059; /* Accent Gold for the unit */
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-left: 4px;
    line-height: 1;
    display: inline-block;
  }

  /* Editor Container */
  .ql-container.ql-snow {
    border: none !important;
    font-family: inherit !important;
    font-size: 1.15rem;
    color: #ffffff;
  }

  .ql-editor {
    min-height: 500px;
    padding: 40px !important;
    line-height: 2;
    background: transparent;
  }

  .ql-editor.ql-blank::before {
    color: rgba(255, 255, 255, 0.15) !important;
    font-style: normal !important;
    left: 40px !important;
  }

  /* Pickers (Dropdowns) */
  .ql-snow .ql-picker-options {
    background-color: #1a1a1a !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    padding: 10px !important;
    border-radius: 8px;
  }

  .ql-snow .ql-picker-item {
    color: rgba(255, 255, 255, 0.5) !important;
    padding: 5px 10px !important;
  }

  .ql-snow .ql-picker-item:hover,
  .ql-snow .ql-picker-item.ql-selected {
    color: var(--color-accent) !important;
    background: rgba(255, 255, 255, 0.05);
  }
</style>
