---
import '../styles/global.css';

interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Admin Marchive</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
</head>
<body class="bg-[#0a0a0a] text-white font-sans antialiased">
  <!-- Mobile Menu Button -->
  <button id="admin-mobile-toggle" class="fixed top-5 left-5 z-[9000] lg:hidden bg-black text-accent border border-accent px-[15px] py-2 font-bold text-[0.7rem] tracking-[0.1em] rounded-[4px] cursor-pointer">
    <span>MENU</span>
  </button>

  <!-- Sidebar Overlay -->
  <div id="sidebar-overlay" class="fixed top-0 left-0 w-full h-full bg-black/90 backdrop-blur-[10px] z-[9998] hidden [&.open]:block"></div>

  <div class="flex min-h-screen bg-[#0a0a0a] text-white">
    <aside id="admin-sidebar" class="fixed top-0 left-0 h-full w-[280px] bg-black border-r border-glass-border p-[40px_20px] flex flex-col z-[9999] transition-all duration-400 cubic-bezier-[0.77,0,0.175,1] max-lg:-left-full lg:left-0 [&.open]:left-0 shadow-[20px_0_50px_rgba(0,0,0,0.8)] lg:shadow-none">
      <a href="/admin" class="font-serif text-2xl text-accent mb-[60px] tracking-[0.1em] no-underline">MARCHIVE ADMIN</a>
      
      <nav class="flex flex-col gap-2.5">
        <a href="/admin" class={`flex items-center gap-3 p-[12px_15px] rounded-lg text-white text-[0.85rem] no-underline transition-all duration-300 opacity-70 hover:bg-accent/10 hover:text-accent hover:opacity-100 ${activePage === 'dashboard' ? '!bg-accent/10 !text-accent !opacity-100' : ''}`}>
          <span>Dashboard</span>
        </a>

        <div class="text-[0.65rem] tracking-[0.2em] opacity-40 mt-5 mb-2.5 ml-2.5 uppercase">Archives</div>
        <a href="/admin/works" class={`flex items-center gap-3 p-[12px_15px] rounded-lg text-white text-[0.85rem] no-underline transition-all duration-300 opacity-70 hover:bg-accent/10 hover:text-accent hover:opacity-100 ${activePage === 'works' || activePage === 'new-work' ? 'bg-accent/10 text-accent opacity-100' : ''}`}>
          <span>Content List</span>
        </a>
        
        <div class="text-[0.65rem] tracking-[0.2em] opacity-40 mt-5 mb-2.5 ml-2.5 uppercase">Organization</div>
        <a href="/admin/categories" class={`flex items-center gap-3 p-[12px_15px] rounded-lg text-white text-[0.85rem] no-underline transition-all duration-300 opacity-70 hover:bg-accent/10 hover:text-accent hover:opacity-100 ${activePage === 'categories' ? 'bg-accent/10 text-accent opacity-100' : ''}`}>
          <span>Categories</span>
        </a>
        
        <div class="text-[0.65rem] tracking-[0.2em] opacity-40 mt-5 mb-2.5 ml-2.5 uppercase">System</div>
        <a href="/admin/settings" class="flex items-center gap-3 p-[12px_15px] rounded-lg text-white text-[0.85rem] no-underline transition-all duration-300 opacity-70 hover:bg-accent/10 hover:text-accent hover:opacity-100">
          <span>Settings</span>
        </a>
        <a href="/" class="flex items-center gap-3 p-[12px_15px] rounded-lg text-white text-[0.85rem] no-underline transition-all duration-300 opacity-70 hover:bg-accent/10 hover:text-accent hover:opacity-100">
          <span>View Site</span>
        </a>
      </nav>
    </aside>

    <main class="flex-1 lg:ml-[280px] p-5 lg:p-[60px] pt-20 lg:pt-[60px]">
      <header class="mb-[60px]">
        <h1 class="text-[2.5rem] font-serif">{title}</h1>
      </header>
      
      <slot />
    </main>
  </div>

  <script>
    const toggle = document.getElementById('admin-mobile-toggle');
    const sidebar = document.getElementById('admin-sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    function toggleMenu() {
      sidebar?.classList.toggle('open');
      overlay?.classList.toggle('open');
    }

    toggle?.addEventListener('click', toggleMenu);
    overlay?.addEventListener('click', toggleMenu);
  </script>
</body>
</html>

