---
import { db } from '../db';
import { users } from '../db/schema';
import { eq } from 'drizzle-orm';
import bcrypt from 'bcryptjs';
import { createToken } from '../lib/auth';
import '../styles/global.css';

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const identifier = data.get('identifier')?.toString();
    const passkey = data.get('passkey')?.toString();

    if (identifier && passkey) {
      // 1. Find user in DB
      const [user] = await db.select().from(users).where(eq(users.username, identifier)).limit(1);

      if (user) {
        // 2. Compare password
        const isValid = await bcrypt.compare(passkey, user.password);

        if (isValid) {
          // 3. Create Token
          const token = await createToken({ id: user.id, username: user.username });

          // 4. Set Cookie
          Astro.cookies.set('marchive_auth_token', token, {
            path: '/',
            httpOnly: true,
            secure: import.meta.env.PROD,
            sameSite: 'strict',
            maxAge: 60 * 60 * 24 // 24 hours
          });

          return Astro.redirect('/admin');
        }
      }
      error = 'INVALID IDENTIFIER OR PASSKEY';
    }
  } catch (e) {
    error = 'SYSTEM ERROR. PLEASE RETRY ACCESS.';
    console.error(e);
  }
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>LOGIN | MARCHIVE ACCESS</title>
	</head>
	<body class="bg-[#050505] text-white font-sans antialiased">
    <main class="min-h-screen flex items-center justify-center p-5 relative overflow-hidden">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full pointer-events-none opacity-20">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/20 rounded-full blur-[120px]"></div>
      </div>

      <div class="w-full max-w-[420px] bg-white/3 backdrop-blur-[20px] border border-glass-border p-[60px_40px] rounded-[24px] shadow-[0_20px_50px_rgba(0,0,0,0.5)] z-10 fade-in">
        <header class="text-center mb-[40px]">
          <p class="text-[0.65rem] tracking-[0.3em] uppercase opacity-40 mb-2.5">Restricted Area</p>
          <h1 class="text-[2.5rem] tracking-[0.2em] font-serif">MARCHIVE</h1>
          <div class="w-[30px] h-[1px] bg-accent mx-auto mt-5"></div>
        </header>

        {error && <div class="text-accent bg-accent/5 p-3 rounded border border-accent/20 text-[0.7rem] text-center mb-5 tracking-[0.1em]">{error}</div>}

        <form class="flex flex-col gap-6" method="POST">
          <div class="flex flex-col gap-2">
            <label for="identifier" class="text-[0.6rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">ACCESS IDENTIFIER</label>
            <input type="text" id="identifier" name="identifier" placeholder="Username or Email" required class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all placeholder:opacity-20" />
          </div>

          <div class="flex flex-col gap-2">
            <label for="passkey" class="text-[0.6rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">SECURE PASSKEY</label>
            <input type="password" id="passkey" name="passkey" placeholder="••••••••" required class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all placeholder:opacity-20" />
          </div>

          <button type="submit" class="mt-[10px] bg-accent text-black p-5 rounded-lg font-bold text-[0.8rem] tracking-[0.2em] uppercase transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] cursor-pointer">AUTHORIZE ACCESS</button>
        </form>

        <a href="/" class="block text-center mt-[40px] text-[0.7rem] tracking-[0.1em] opacity-40 no-underline transition-all hover:opacity-100 hover:text-accent">&larr; RETURN TO PUBLIC ARCHIVE</a>
      </div>
    </main>
	</body>
</html>
