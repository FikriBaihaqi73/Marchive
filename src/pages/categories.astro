---
import Layout from '@layouts/Layout.astro';
import { db } from '@db/index';
import { categories as categoryTable, works as worksTable } from '@db/schema';
import { eq, count, desc } from 'drizzle-orm';

// 1. Fetch all categories from database
const dbCategories = await db.select().from(categoryTable);

// 2. Build categorized data with real counts and covers
const categorizedWorks = await Promise.all(dbCategories.map(async (cat) => {
  // Count works in this category
  const [workCount] = await db
    .select({ value: count() })
    .from(worksTable)
    .where(eq(worksTable.categoryId, cat.id));

  // Get top 3 covers for the collage
  const recentWorks = await db
    .select({ cover: worksTable.cover })
    .from(worksTable)
    .where(eq(worksTable.categoryId, cat.id))
    .orderBy(desc(worksTable.createdAt))
    .limit(3);

  return {
    name: cat.name,
    count: workCount.value,
    covers: recentWorks.map(w => w.cover).filter(Boolean) as string[]
  };
}));
---


<Layout>
  <main class="pt-[180px] max-md:pt-[120px] pb-[150px] container">
    <header class="text-center mb-[100px] max-md:mb-[60px]">
      <div class="flex items-center gap-[15px] justify-center text-[0.9rem] font-medium mb-5">03</div>
      <h1 class="text-[3rem] lg:text-[5rem] tracking-[0.1em] fade-in">COLLECTIONS</h1>
      <p class="text-[0.9rem] tracking-[0.3em] opacity-50 uppercase fade-in">Browse the archive by creative chambers.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-[60px] lg:gap-x-[60px] lg:gap-y-[100px]">
      {categorizedWorks.map((cat) => (
        <a href={`/works?filter=${cat.name.toLowerCase()}`} class="group block no-underline text-inherit transition-transform duration-400 hover:-translate-y-2.5 fade-in">
          <div class="relative w-full aspect-[4/3] bg-white/2 border border-glass-border overflow-hidden mb-[30px]">
            {/* Collage stack Effect */}
            <div class="relative w-full h-full p-10 max-md:p-5 flex items-center justify-center">
              {cat.covers.map((cover, idx) => (
                <div class={`absolute w-1/2 aspect-[3/4] bg-[#111] border border-white/10 shadow-[10px_10px_30px_rgba(0,0,0,0.5)] overflow-hidden transition-all duration-500 cubic-bezier-[0.4,0,0.2,1] 
                  ${idx === 0 ? 'z-[3] -rotate-2 group-hover:rotate-0' : ''}
                  ${idx === 1 ? 'z-[2] translate-x-[30%] translate-y-[15%] rotate-[5deg] opacity-80 group-hover:translate-x-[45%] group-hover:translate-y-[25%] group-hover:rotate-[10deg]' : ''}
                  ${idx === 2 ? 'z-[1] -translate-x-[30%] -translate-y-[15%] -rotate-[8deg] opacity-60 group-hover:-translate-x-[45%] group-hover:-translate-y-[25%] group-hover:-rotate-[15deg]' : ''}
                `}>
                  <img src={cover} alt="" class="w-full h-full object-cover" />
                </div>
              ))}
              {/* Fallback pattern if only 1-2 covers exist */}
              {cat.covers.length < 3 && (
                <div class="absolute w-1/2 aspect-[3/4] bg-accent z-0 flex items-center justify-center">
                  <span class="text-[0.6rem] text-black font-black tracking-[0.2em] -rotate-90">MARCHIVE</span>
                </div>
              )}
            </div>
            
            <div class="absolute top-0 left-0 w-full h-full bg-black/40 flex items-center justify-center opacity-0 transition-opacity duration-400 backdrop-blur-[2px] z-10 group-hover:opacity-100">
              <span class="text-[0.75rem] font-bold tracking-[0.2em] bg-accent text-black p-[12px_24px]">EXPLORE ROOM &rarr;</span>
            </div>
          </div>
          
          <div>
            <div class="flex justify-between items-baseline mb-2.5">
              <h2 class="text-[1.8rem] font-serif tracking-[0.05em]">{cat.name}</h2>
              <span class="text-[0.7rem] opacity-40 font-bold tracking-[0.1em]">{cat.count} {cat.count > 1 ? 'WORKS' : 'WORK'}</span>
            </div>
            <div class="w-10 h-[1px] bg-accent transition-all duration-400 group-hover:w-full"></div>
          </div>
        </a>
      ))}
    </div>
  </main>
