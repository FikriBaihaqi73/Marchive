---
import Layout from '@layouts/Layout.astro';
import { db } from '@db/index';
import { categories as categoryTable, works as worksTable } from '@db/schema';
import { eq, count, desc } from 'drizzle-orm';

// 1. Fetch all categories from database
const dbCategories = await db.select().from(categoryTable);

// 2. Build categorized data with real counts and covers
const categorizedWorks = await Promise.all(dbCategories.map(async (cat) => {
  // Count works in this category
  const [workCount] = await db
    .select({ value: count() })
    .from(worksTable)
    .where(eq(worksTable.categoryId, cat.id));

  // Get top 3 covers for the collage
  const recentWorks = await db
    .select({ cover: worksTable.cover })
    .from(worksTable)
    .where(eq(worksTable.categoryId, cat.id))
    .orderBy(desc(worksTable.createdAt))
    .limit(3);

  return {
    name: cat.name,
    count: workCount.value,
    covers: recentWorks.map(w => w.cover).filter(Boolean) as string[]
  };
}));
---


<Layout>
  <main class="pt-[150px] max-md:pt-[100px] pb-[120px] container">
    <header class="text-center mb-[80px] max-md:mb-[50px]">
      <div class="flex items-center gap-[15px] justify-center text-[0.8rem] font-medium mb-4 opacity-50">03</div>
      <h1 class="text-[2.8rem] lg:text-[5rem] tracking-[0.05em] fade-in uppercase font-serif">Collections</h1>
      <p class="text-[0.7rem] lg:text-[0.9rem] tracking-[0.2em] opacity-50 uppercase fade-in max-w-[300px] mx-auto leading-relaxed">Browse the archive by creative chambers.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-[60px] lg:gap-x-[80px] lg:gap-y-[120px]">
      {categorizedWorks.map((cat) => (
        <a href={`/works?filter=${cat.name.toLowerCase()}`} class="group block no-underline text-inherit transition-all duration-400 fade-in">
          <div class="relative w-full aspect-[4/3] bg-white/2 border border-glass-border overflow-hidden mb-[25px]">
            {/* Collage stack Effect */}
            <div class="relative w-full h-full flex items-center justify-center p-10">
              {cat.covers.map((cover, idx) => (
                <div class={`absolute w-[45%] aspect-[3/4] bg-[#111] border border-white/10 shadow-[20px_20px_40px_rgba(0,0,0,0.6)] overflow-hidden transition-all duration-700 cubic-bezier-[0.23,1,0.32,1] 
                  ${idx === 0 ? 'z-[3] -rotate-2 group-hover:rotate-0' : ''}
                  ${idx === 1 ? 'z-[2] translate-x-[25%] translate-y-[10%] rotate-[6deg] opacity-80 group-hover:translate-x-[40%] group-hover:translate-y-[20%] group-hover:rotate-[12deg]' : ''}
                  ${idx === 2 ? 'z-[1] -translate-x-[25%] -translate-y-[10%] -rotate-[10deg] opacity-60 group-hover:-translate-x-[40%] group-hover:-translate-y-[20%] group-hover:-rotate-[18deg]' : ''}
                `}>
                  <img src={cover} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                </div>
              ))}
              {/* Fallback pattern if empty */}
              {cat.covers.length === 0 && (
                <div class="w-1/3 aspect-[3/4] border border-white/10 bg-white/5 flex items-center justify-center">
                   <span class="text-[0.6rem] opacity-20 tracking-widest">EMPTY</span>
                </div>
              )}
            </div>
            
            <div class="absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 transition-all duration-400 backdrop-blur-[4px] z-10 group-hover:opacity-100">
              <span class="text-[0.7rem] font-bold tracking-[0.2em] bg-white text-black p-[12px_24px] translate-y-4 transition-transform group-hover:translate-y-0">EXPLORE ROOM &rarr;</span>
            </div>
          </div>
          
          <div class="px-2">
            <div class="flex justify-between items-baseline mb-3">
              <h2 class="text-[1.5rem] lg:text-[1.8rem] font-serif tracking-[0.05em] uppercase">{cat.name}</h2>
              <span class="text-[0.65rem] opacity-40 font-bold tracking-[0.1em]">{cat.count} {cat.count > 1 ? 'ITEMS' : 'ITEM'}</span>
            </div>
            <div class="w-full h-[1px] bg-white/10 relative overflow-hidden">
              <div class="absolute top-0 left-0 h-full w-0 bg-accent transition-all duration-500 group-hover:w-full"></div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  @reference "../styles/global.css";
</style>
