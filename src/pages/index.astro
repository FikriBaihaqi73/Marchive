---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import LatestWorks from '@components/LatestWorks.astro';
---

<Layout>
	<main class="pt-[100px] relative">
    <!-- Sidebar decoration -->
    <div class="fixed left-10 top-1/2 -translate-y-1/2 -rotate-90 origin-left text-[0.65rem] tracking-[0.3em] opacity-50 z-10 hidden lg:block">SCROLL TO DISCOVER</div>
    <div class="fixed right-10 top-1/2 -translate-y-1/2 flex flex-col gap-[30px] text-[0.6rem] tracking-[0.2em] opacity-50 z-10 hidden lg:flex">
      <a href="#" class="no-underline text-inherit hover:text-accent transition-colors">INSTAGRAM</a>
      <a href="#" class="no-underline text-inherit hover:text-accent transition-colors">TWITTER</a>
      <a href="#" class="no-underline text-inherit hover:text-accent transition-colors">EMAIL</a>
    </div>

    <Hero />
    <LatestWorks />

	</main>
</Layout>
