---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/index';
import { works as worksTable, categories as categoryTable, chapters as chaptersTable } from '@schema/index';
import { eq, asc, count } from 'drizzle-orm';

const { id } = Astro.params;
const workId = parseInt(id || '0');

// 1. Fetch work details
const [work] = await db
  .select({
    id: worksTable.id,
    title: worksTable.title,
    cover: worksTable.cover,
    synopsis: worksTable.synopsis,
    status: worksTable.status,
    type: worksTable.type,
    categoryName: categoryTable.name,
    createdAt: worksTable.createdAt
  })
  .from(worksTable)
  .leftJoin(categoryTable, eq(worksTable.categoryId, categoryTable.id))
  .where(eq(worksTable.id, workId))
  .limit(1);

if (!work) return Astro.redirect('/admin/works');

// 2. Fetch chapters if it's a book
let chapters: any[] = [];
if (work.type === 'book') {
  chapters = await db
    .select()
    .from(chaptersTable)
    .where(eq(chaptersTable.workId, workId))
    .orderBy(asc(chaptersTable.order));
}

// 3. Handle POST Actions
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action')?.toString();

  if (action === 'delete-work') {
    await db.delete(worksTable).where(eq(worksTable.id, workId));
    return Astro.redirect('/admin/works');
  }

  if (action === 'publish-work') {
    await db.update(worksTable).set({ status: 'published' }).where(eq(worksTable.id, workId));
    return Astro.redirect(`/admin/works/${workId}`);
  }

  if (action === 'unpublish-work') {
    await db.update(worksTable).set({ status: 'draft' }).where(eq(worksTable.id, workId));
    return Astro.redirect(`/admin/works/${workId}`);
  }

  if (action === 'delete-chapter') {
    const chapterId = parseInt(data.get('chapterId')?.toString() || '0');
    if (chapterId) {
      await db.delete(chaptersTable).where(eq(chaptersTable.id, chapterId));
      return Astro.redirect(`/admin/works/${workId}`);
    }
  }
}
---

<AdminLayout title={`Manage: ${work.title}`} activePage="works">
  <div class="flex flex-col lg:flex-row justify-between items-end mb-[50px] border-b border-glass-border pb-[30px] gap-5">
    <div class="header-left">
      <a href="/admin/works" class="text-[0.7rem] tracking-[0.1em] opacity-50 no-underline mb-[15px] block hover:opacity-100 hover:text-accent">&larr; BACK TO ARCHIVE</a>
      <h1 class="text-[2.5rem] font-serif mb-[15px] leading-tight">{work.title}</h1>
      <div class="flex gap-[15px] items-center">
        <span class={`px-3 py-1 rounded-full text-[0.65rem] font-bold uppercase ${work.status === 'published' ? 'bg-green-500/10 text-green-400' : 'bg-orange-500/10 text-orange-400'}`}>{work.status.toUpperCase()}</span>
        <span class="text-[0.65rem] tracking-[0.1em] font-bold opacity-60 uppercase">{work.type === 'book' ? '📚 BOOK' : '📄 SINGLE PIECE'}</span>
        <span class="text-[0.65rem] tracking-[0.1em] font-bold opacity-60 uppercase">{work.categoryName}</span>
      </div>
    </div>
    <div class="flex gap-[15px] flex-wrap items-center">
      <a href={`/admin/works/${work.id}/edit`} class="bg-white/5 text-white border border-glass-border px-5 py-3 rounded-lg font-bold text-[0.8rem] no-underline hover:bg-white/10 transition-all">EDIT METADATA</a>
      
      {work.status === 'draft' ? (
        <form method="POST" class="contents">
          <input type="hidden" name="action" value="publish-work" />
          <button type="submit" class="bg-accent text-black px-5 py-3 rounded-lg font-bold text-[0.8rem] hover:scale-105 transition-all cursor-pointer">PUBLISH WORK</button>
        </form>
      ) : (
        <form method="POST" class="contents">
          <input type="hidden" name="action" value="unpublish-work" />
          <button type="submit" class="bg-white/10 text-white border border-white/20 px-5 py-3 rounded-lg font-bold text-[0.8rem] hover:bg-white/20 transition-all cursor-pointer">SET TO DRAFT</button>
        </form>
      )}

      <button type="button" class="bg-transparent text-red-500 border border-red-500 px-5 py-3 rounded-lg font-bold text-[0.8rem] hover:bg-red-500 hover:text-black transition-all cursor-pointer" id="delete-work-btn">DELETE WORK</button>
    </div>
  </div>

  <form id="delete-work-form" method="POST" class="hidden">
    <input type="hidden" name="action" value="delete-work" />
  </form>

  <div class="grid grid-cols-1 lg:grid-cols-[250px,1fr] gap-[50px]">
    <!-- Sidebar Info -->
    <aside class="flex flex-col gap-5">
      <div class="bg-white/3 border border-glass-border p-2.5 rounded-xl">
        <img src={work.cover || "https://via.placeholder.com/225x337"} alt={work.title} class="w-full aspect-[2/3] object-cover rounded-lg" />
      </div>
      
      <div class="bg-white/3 border border-glass-border p-5 rounded-xl">
        <div class="flex flex-col gap-[5px] mb-[15px]">
          <span class="text-[0.6rem] tracking-[0.1em] opacity-40 font-bold uppercase">CREATED</span>
          <span class="text-[0.9rem] font-semibold">{new Date(work.createdAt).toLocaleDateString()}</span>
        </div>
        {work.type === 'book' && (
          <div class="flex flex-col gap-[5px]">
            <span class="text-[0.6rem] tracking-[0.1em] opacity-40 font-bold uppercase">CHAPTERS</span>
            <span class="text-[0.9rem] font-semibold">{chapters.length}</span>
          </div>
        )}
      </div>
    </aside>

    <!-- Main Content Area -->
    <main>
      {work.type === 'book' ? (
        <div>
          <div class="flex justify-between items-center mb-[30px]">
            <h2 class="text-[0.8rem] tracking-[0.2em] opacity-50 font-bold uppercase">CHAPTER LIST</h2>
            <a href={`/admin/works/${work.id}/chapters/new`} class="text-[0.7rem] font-bold tracking-[0.1em] text-accent border border-accent p-[10px_20px] no-underline transition-all hover:bg-accent hover:text-black">+ ADD NEW CHAPTER</a>
          </div>

          <div class="flex flex-col gap-[15px]">
            {chapters.map((chapter) => (
              <div class="bg-white/2 border border-glass-border p-[20px_30px] flex justify-between items-center rounded-lg hover:border-accent/50 transition-all">
                <div class="flex items-center gap-[30px]">
                  <span class="text-[0.65rem] font-extrabold opacity-30 w-[60px] uppercase">CH {chapter.order}</span>
                  <h3 class="text-[1rem] font-medium">{chapter.title}</h3>
                </div>
                <div class="flex gap-[15px] items-center">
                  <a href={`/admin/works/${work.id}/chapters/${chapter.id}`} class="text-[0.7rem] font-bold text-white opacity-60 no-underline hover:opacity-100 hover:text-accent">EDIT</a>
                  <form method="POST" onsubmit="return confirm('Delete this chapter?');" class="inline">
                    <input type="hidden" name="action" value="delete-chapter" />
                    <input type="hidden" name="chapterId" value={chapter.id} />
                    <button type="submit" class="text-[1.2rem] text-red-500 opacity-50 hover:opacity-100">&times;</button>
                  </form>
                </div>
              </div>
            ))}
            {chapters.length === 0 && (
              <div class="text-center py-20 opacity-30 border border-dashed border-glass-border rounded-lg">
                <p>This book has no chapters yet. Start your story!</p>
              </div>
            )}
          </div>
        </div>
      ) : (
        <div class="single-piece-management">
          <div class="flex justify-between items-center mb-[30px]">
            <h2 class="text-[0.8rem] tracking-[0.2em] opacity-50 font-bold uppercase">CONTENT PREVIEW</h2>
            <a href={`/admin/works/${work.id}/edit`} class="text-[0.7rem] font-bold tracking-[0.1em] text-accent border border-accent p-[10px_20px] no-underline transition-all hover:bg-accent hover:text-black">EDIT CONTENT</a>
          </div>
          <div class="bg-white/3 border border-glass-border p-[30px] rounded-xl">
             {work.synopsis && <div class="mb-[30px] pb-5 border-b border-white/5"><strong class="text-[0.7rem] tracking-[0.1em] block mb-2.5 opacity-40 uppercase">Synopsis:</strong> <p>{work.synopsis}</p></div>}
             <div class="opacity-50 italic">
               Content editing is available via the "Edit Content" button.
             </div>
          </div>
        </div>
      )}
    </main>
  </div>
</AdminLayout>

<script is:inline>
  document.getElementById('delete-work-btn')?.addEventListener('click', () => {
    if (confirm('Are you sure you want to delete this entire work? This will delete all its chapters and cannot be undone.')) {
      document.getElementById('delete-work-form')?.submit();
    }
  });
</script>

