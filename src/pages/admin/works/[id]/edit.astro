---
import AdminLayout from '@layouts/AdminLayout.astro';
import RichTextEditor from '@components/admin/RichTextEditor.astro';
import { db } from '@db/index';
import { works as worksTable, categories as categoryTable } from '@schema/index';
import { eq } from 'drizzle-orm';

const { id } = Astro.params;
const workId = parseInt(id || '0');

// 1. Fetch current work data
const [work] = await db.select().from(worksTable).where(eq(worksTable.id, workId)).limit(1);

if (!work) return Astro.redirect('/admin/works');

// 2. Fetch categories for dropdown
const categories = await db.select().from(categoryTable).where(eq(categoryTable.type, work.type));

let error = '';
let success = '';

// 3. Handle POST Actions
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action')?.toString();

    if (action === 'delete') {
      await db.delete(worksTable).where(eq(worksTable.id, workId));
      return Astro.redirect('/admin/works');
    }

    const title = data.get('title')?.toString();
    const categoryId = parseInt(data.get('categoryId')?.toString() || '0');
    const cover = data.get('cover')?.toString();
    const synopsis = data.get('synopsis')?.toString();
    const content = data.get('content')?.toString();

    if (title && categoryId) {
      await db.update(worksTable)
        .set({ 
          title, 
          categoryId, 
          cover, 
          synopsis: work.type === 'book' ? synopsis : null,
          content: work.type === 'single' ? content : null
        })
        .where(eq(worksTable.id, workId));

      success = 'Work updated successfully!';
    } else {
      error = 'Title and Category are required.';
    }
  } catch (e) {
    error = 'Failed to process request.';
    console.error(e);
  }
}

const isSingle = work.type === 'single';
---

<AdminLayout title={`Edit Metadata: ${work.title}`} activePage="works">
  <div class="max-w-[900px]">
    <div class="mb-[50px]">
      <a href={`/admin/works/${workId}`} class="text-[0.7rem] tracking-[0.1em] opacity-50 no-underline mb-[15px] block hover:opacity-100 hover:text-accent">&larr; BACK TO MANAGEMENT</a>
      <h1 class="text-[2.5rem] font-serif leading-tight">Edit Work Metadata</h1>
      <p class="opacity-50 mt-2">Managing basic info for: <strong>{work.title}</strong></p>
    </div>

    {error && <div class="bg-red-500/10 text-red-500 p-[15px] rounded-lg mb-[30px] border border-red-500/20 text-[0.85rem]">{error}</div>}
    {success && <div class="bg-green-500/10 text-green-400 p-[15px] rounded-lg mb-[30px] border border-green-500/20 text-[0.85rem]">{success}</div>}

    <form class="flex flex-col gap-6" method="POST" id="edit-work-form">
      <input type="hidden" name="content" id="hidden-content" />
      <input type="hidden" name="action" id="form-action" value="update" />

      <div class="flex flex-col gap-2">
        <label for="title" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">TITLE</label>
        <input type="text" id="title" name="title" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[1rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all" value={work.title} required />
      </div>

      <div class="flex flex-col gap-2">
        <label for="categoryId" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CATEGORY</label>
        <select id="categoryId" name="categoryId" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all appearance-none cursor-pointer" required>
          {categories.map(cat => (
            <option value={cat.id} selected={cat.id === work.categoryId} class="bg-[#0a0a0a]">{cat.name}</option>
          ))}
        </select>
      </div>

      <div class="flex flex-col gap-2">
        <label for="cover" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">COVER IMAGE URL</label>
        <input type="text" id="cover" name="cover" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all" value={work.cover || ''} placeholder="https://image-link.com/photo.jpg" />
      </div>

      {isSingle ? (
        <div class="flex flex-col gap-2">
          <label class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CONTENT EDITOR</label>
          <RichTextEditor initialValue={work.content || ''} />
        </div>
      ) : (
        <div class="flex flex-col gap-2">
          <label for="synopsis" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">SYNOPSIS / DESCRIPTION</label>
          <textarea id="synopsis" name="synopsis" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all resize-none" rows="8">{work.synopsis}</textarea>
        </div>
      )}

      <div class="mt-10 pt-[30px] border-t border-white/5 flex gap-[15px]">
        <button type="submit" class="bg-accent text-black px-8 py-4 rounded-lg font-bold text-[0.8rem] tracking-[0.1em] transition-all hover:scale-105 active:scale-95 cursor-pointer">SAVE ALL CHANGES</button>
        <button type="button" class="bg-transparent text-red-500 border border-red-500 px-8 py-4 rounded-lg font-bold text-[0.8rem] tracking-[0.1em] hover:bg-red-500 hover:text-black transition-all cursor-pointer" id="delete-btn">DELETE WORK</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script is:inline>
  const form = document.getElementById('edit-work-form');
  const hiddenInput = document.getElementById('hidden-content');
  const actionInput = document.getElementById('form-action');

  form?.addEventListener('submit', (e) => {
    if (window.quill) {
      hiddenInput.value = window.quill.root.innerHTML;
    }
  });

  // Delete Work
  document.getElementById('delete-btn')?.addEventListener('click', () => {
    if (confirm('Are you sure you want to delete this entire work? This will also delete all associated chapters. This action cannot be undone.')) {
      if (actionInput && form) {
        actionInput.value = 'delete';
        form.submit();
      }
    }
  });
</script>
