---
import AdminLayout from '@layouts/AdminLayout.astro';
import RichTextEditor from '@components/admin/RichTextEditor.astro';
import { db } from '@db/index';
import { chapters as chaptersTable, works as worksTable } from '@schema/index';
import { eq, and } from 'drizzle-orm';

const { id, chapterId } = Astro.params;
const workId = parseInt(id || '0');
const chId = parseInt(chapterId || '0');

// 1. Fetch current chapter data
const [chapter] = await db
  .select()
  .from(chaptersTable)
  .where(
    and(
      eq(chaptersTable.id, chId),
      eq(chaptersTable.workId, workId)
    )
  )
  .limit(1);

if (!chapter) return Astro.redirect(`/admin/works/${workId}`);

// 2. Fetch parent work info
const [work] = await db.select().from(worksTable).where(eq(worksTable.id, workId)).limit(1);

let error = '';
let success = '';

// 3. Handle POST Actions
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action')?.toString();

    if (action === 'delete') {
      await db.delete(chaptersTable).where(eq(chaptersTable.id, chId));
      return Astro.redirect(`/admin/works/${workId}`);
    }

    const title = data.get('title')?.toString();
    const order = parseInt(data.get('order')?.toString() || '0');
    const content = data.get('content')?.toString();

    if (title && content) {
      await db.update(chaptersTable)
        .set({ title, order, content })
        .where(eq(chaptersTable.id, chId));

      success = 'Chapter updated successfully!';
    } else {
      error = 'Title and Content are required.';
    }
  } catch (e) {
    error = 'Failed to process request.';
    console.error(e);
  }
}
---


<AdminLayout title={`Edit Chapter: ${chapter.title}`} activePage="works">
  <div class="max-w-[900px]">
    <div class="mb-[50px]">
      <div class="flex justify-between items-start gap-5 flex-wrap">
        <div>
          <a href={`/admin/works/${workId}`} class="text-[0.7rem] tracking-[0.1em] opacity-50 no-underline mb-[15px] block hover:opacity-100 hover:text-accent transition-all">&larr; BACK TO WORK</a>
          <h1 class="text-[2.5rem] font-serif leading-tight">Edit Chapter</h1>
          <p class="opacity-50 mt-2">Editing: <strong>{chapter.title}</strong> for <em>{work?.title}</em></p>
        </div>
        <div>
           <a href={`/works/${workId}/${chapter.id}`} target="_blank" class="text-[0.7rem] font-bold text-accent border border-accent p-[8px_15px] rounded no-underline hover:bg-accent hover:text-black transition-all">VIEW PUBLIC &rarr;</a>
        </div>
      </div>
    </div>

    {error && (
      <div class="bg-red-500/10 text-red-500 p-[15px] rounded-lg mb-[30px] border border-red-500/20 text-[0.85rem]">
        {error}
      </div>
    )}

    {success && (
      <div class="bg-green-500/10 text-green-400 p-[15px] rounded-lg mb-[30px] border border-green-500/20 text-[0.85rem]">
        {success}
      </div>
    )}

    <form class="flex flex-col gap-6" method="POST" id="edit-chapter-form">
      <input type="hidden" name="content" id="hidden-content" />
      <input type="hidden" name="action" id="form-action" value="update" />
      
      <div class="grid grid-cols-1 sm:grid-cols-[1fr_120px] gap-5">
        <div class="flex flex-col gap-2">
          <label for="title" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CHAPTER TITLE</label>
          <input type="text" id="title" name="title" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[1rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all placeholder:opacity-20" value={chapter.title} required />
        </div>
        <div class="flex flex-col gap-2">
          <label for="order" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">ORDER</label>
          <input type="number" id="order" name="order" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[1rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all" value={chapter.order} required />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CHAPTER CONTENT</label>
        <RichTextEditor initialValue={chapter.content} />
      </div>

      <div class="mt-10 pt-[30px] border-t border-white/5 flex gap-[15px]">
        <button type="submit" class="bg-accent text-black px-8 py-4 rounded-lg font-bold text-[0.8rem] tracking-[0.1em] transition-all hover:scale-105 active:scale-95 cursor-pointer">SAVE CHANGES</button>
        <button type="button" class="bg-transparent text-red-500 border border-red-500 px-8 py-4 rounded-lg font-bold text-[0.8rem] tracking-[0.1em] hover:bg-red-500 hover:text-black transition-all cursor-pointer" id="delete-btn">DELETE CHAPTER</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script is:inline>
  const form = document.getElementById('edit-chapter-form');
  const hiddenInput = document.getElementById('hidden-content');
  const actionInput = document.getElementById('form-action');

  form?.addEventListener('submit', (e) => {
    if (window.quill) {
      hiddenInput.value = window.quill.root.innerHTML;
    }
  });

  // Real Delete Functionality
  document.getElementById('delete-btn')?.addEventListener('click', () => {
    if (confirm('Are you sure you want to delete this chapter? This action cannot be undone.')) {
      if (actionInput && form) {
        actionInput.value = 'delete';
        form.submit();
      }
    }
  });
</script>
