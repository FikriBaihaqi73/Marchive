---
import AdminLayout from '@layouts/AdminLayout.astro';
import RichTextEditor from '@components/admin/RichTextEditor.astro';
import { db } from '@db/index';
import { chapters as chaptersTable, works as worksTable } from '@schema/index';
import { eq, count } from 'drizzle-orm';

const { id } = Astro.params;
const workId = parseInt(id || '0');

// Fetch work to confirm it exists
const [work] = await db.select().from(worksTable).where(eq(worksTable.id, workId)).limit(1);
if (!work) return Astro.redirect('/admin/works');

// Get next order number
const [{ count: currentChapters }] = await db
  .select({ count: count(chaptersTable.id) })
  .from(chaptersTable)
  .where(eq(chaptersTable.workId, workId));

const nextOrder = currentChapters + 1;

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const title = data.get('title')?.toString();
    const order = parseInt(data.get('order')?.toString() || nextOrder.toString());
    const content = data.get('content')?.toString();

    if (title && content) {
      await db.insert(chaptersTable).values({
        workId,
        title,
        content,
        order,
        status: 'published' // Default to published for now
      });

      return Astro.redirect(`/admin/works/${workId}`);
    } else {
      error = 'Title and Content are required.';
    }
  } catch (e) {
    error = 'Failed to save chapter.';
    console.error(e);
  }
}
---

<AdminLayout title={`New Chapter: ${work.title}`} activePage="works">
  <div class="max-w-[900px]">
    <div class="mb-[50px]">
      <a href={`/admin/works/${workId}`} class="text-[0.7rem] tracking-[0.1em] opacity-50 no-underline mb-[15px] block hover:opacity-100 hover:text-accent transition-all">&larr; CANCEL & RETURN</a>
      <h1 class="text-[2.5rem] font-serif leading-tight">New Chapter</h1>
      <p class="opacity-50 mt-2">Writing for: <strong>{work.title}</strong></p>
    </div>

    {error && (
      <div class="bg-red-500/10 text-red-500 p-[15px] rounded-lg mb-[30px] border border-red-500/20 text-[0.85rem]">
        {error}
      </div>
    )}

    <form class="flex flex-col gap-6" method="POST" id="chapter-form">
      <input type="hidden" name="content" id="hidden-content" />
      
      <div class="grid grid-cols-1 sm:grid-cols-[1fr_120px] gap-5">
        <div class="flex flex-col gap-2">
          <label for="title" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CHAPTER TITLE</label>
          <input type="text" id="title" name="title" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[1rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all placeholder:opacity-20" placeholder="e.g. The Beginning of the End" required />
        </div>
        <div class="flex flex-col gap-2">
          <label for="order" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">ORDER</label>
          <input type="number" id="order" name="order" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[1rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all" value={nextOrder} required />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CHAPTER CONTENT</label>
        <RichTextEditor placeholder="Start writing your story here..." />
      </div>

      <div class="mt-10 pt-[30px] border-t border-white/5">
        <button type="submit" class="bg-accent text-black px-10 py-4 rounded-lg font-bold text-[0.85rem] tracking-[0.1em] transition-all hover:scale-105 active:scale-95 cursor-pointer">PUBLISH CHAPTER</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script is:inline>
  const form = document.getElementById('chapter-form');
  const hiddenInput = document.getElementById('hidden-content');

  form?.addEventListener('submit', (e) => {
    if (window.quill) {
      hiddenInput.value = window.quill.root.innerHTML;
    }
  });
</script>
