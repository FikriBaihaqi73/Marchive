---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/index';
import { works as worksTable, categories as categoryTable, chapters as chaptersTable } from '@schema/index';
import { desc, eq, count } from 'drizzle-orm';

// Fetch real works from database with chapter counts
const works = await Promise.all((await db
  .select({
    id: worksTable.id,
    title: worksTable.title,
    category: categoryTable.name,
    status: worksTable.status,
    createdAt: worksTable.createdAt,
    cover: worksTable.cover,
    type: worksTable.type
  })
  .from(worksTable)
  .leftJoin(categoryTable, eq(worksTable.categoryId, categoryTable.id))
  .orderBy(desc(worksTable.createdAt))).map(async (work) => {
    // Get chapter count for each work
    const [{ count: chaptersCount }] = await db
      .select({ count: count(chaptersTable.id) })
      .from(chaptersTable)
      .where(eq(chaptersTable.workId, work.id));
    
    return { ...work, chaptersCount };
  }));
---

<AdminLayout title="Content Archive" activePage="works">
  <div class="works-list-header">
    <div class="header-left">
      <p>Manage your gallery entries and their chapters.</p>
    </div>
    <div class="new-content-dropdown">
      <button class="btn-primary" id="dropdown-toggle">+ New Content</button>
      <div class="dropdown-menu" id="new-content-menu">
        <a href="/admin/works/new?type=book" class="dropdown-item">
          <span class="icon">📚</span>
          <div class="text">
            <strong>Book / Series</strong>
            <small>Chapters, Wattpad style</small>
          </div>
        </a>
        <a href="/admin/works/new?type=single" class="dropdown-item">
          <span class="icon">📄</span>
          <div class="text">
            <strong>Single Piece</strong>
            <small>Poem, Design, Single page</small>
          </div>
        </a>
      </div>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('dropdown-toggle');
    const menu = document.getElementById('new-content-menu');

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      menu?.classList.toggle('show');
    });

    document.addEventListener('click', () => {
      menu?.classList.remove('show');
    });
  </script>

  <div class="story-card-list">
    {works.map(work => (
      <div class="story-card">
        <img src={work.cover || "https://via.placeholder.com/150x225"} alt={work.title} class="story-cover" />
        
        <div class="story-info">
          <h3>{work.title}</h3>
          <div class="story-meta">
            {work.type === 'book' ? (
              <span style="color: var(--accent-color); font-weight: 700;">{work.chaptersCount} Chapters</span>
            ) : (
              <span style="color: #44ff44; font-weight: 700;">Single Piece</span>
            )}
            <span>{new Date(work.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            <span class={`status-badge status-${work.status}`} style="width: fit-content; margin-top: 5px;">{work.status.toUpperCase()}</span>
          </div>
        </div>

        <div class="story-actions">
          <a href={`/admin/works/${work.id}`} class="btn-continue" style="background: rgba(255,255,255,0.05); color: #fff; border: 1px solid var(--glass-border);">Manage Work</a>
        </div>
      </div>
    ))}
    {works.length === 0 && (
      <div style="text-align: center; padding: 100px 0; opacity: 0.3; grid-column: 1/-1;">
        <p>No works found in the archive yet.</p>
      </div>
    )}
  </div>
</AdminLayout>
