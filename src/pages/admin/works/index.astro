---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/index';
import { works as worksTable, categories as categoryTable, chapters as chaptersTable } from '@schema/index';
import { desc, eq, count } from 'drizzle-orm';

// Fetch real works from database with chapter counts
const works = await Promise.all((await db
  .select({
    id: worksTable.id,
    title: worksTable.title,
    category: categoryTable.name,
    status: worksTable.status,
    createdAt: worksTable.createdAt,
    cover: worksTable.cover,
    type: worksTable.type
  })
  .from(worksTable)
  .leftJoin(categoryTable, eq(worksTable.categoryId, categoryTable.id))
  .orderBy(desc(worksTable.createdAt))).map(async (work) => {
    // Get chapter count for each work
    const [{ count: chaptersCount }] = await db
      .select({ count: count(chaptersTable.id) })
      .from(chaptersTable)
      .where(eq(chaptersTable.workId, work.id));
    
    return { ...work, chaptersCount };
  }));
---

<AdminLayout title="Content Archive" activePage="works">
  <div class="flex flex-col lg:flex-row justify-between items-center lg:items-start mb-[30px] gap-5">
    <div class="header-left">
      <p class="opacity-70">Manage your gallery entries and their chapters.</p>
    </div>
    <div class="relative group">
      <button class="bg-accent text-black px-[30px] py-[15px] font-bold tracking-[0.1em] rounded-lg cursor-pointer" id="dropdown-toggle">+ New Content</button>
      <div 
        id="new-content-menu" 
        class="absolute top-full right-0 mt-2.5 bg-[#0b0b0b] border border-accent/30 rounded-xl w-[250px] shadow-[0_20px_50px_rgba(0,0,0,0.8)] hidden z-[5000] overflow-hidden [&.show]:block animate-in fade-in slide-in-from-top-2 duration-300"
      >
        <a href="/admin/works/new?type=book" class="flex items-center gap-[15px] p-[15px_20px] text-white no-underline transition-all duration-300 border-b border-white/5 hover:bg-white/5">
          <span class="text-xl">📚</span>
          <div class="flex flex-col">
            <strong class="text-sm">Book / Series</strong>
            <small class="text-[0.65rem] opacity-50 uppercase tracking-widest mt-1">Chapters, Wattpad style</small>
          </div>
        </a>
        <a href="/admin/works/new?type=single" class="flex items-center gap-[15px] p-[15px_20px] text-white no-underline transition-all duration-300 hover:bg-white/5">
          <span class="text-xl">📄</span>
          <div class="flex flex-col">
            <strong class="text-sm">Single Piece</strong>
            <small class="text-[0.65rem] opacity-50 uppercase tracking-widest mt-1">Poem, Design, Single page</small>
          </div>
        </a>
      </div>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('dropdown-toggle');
    const menu = document.getElementById('new-content-menu');

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      menu?.classList.toggle('show');
    });

    document.addEventListener('click', () => {
      menu?.classList.remove('show');
    });
  </script>

  <div class="flex flex-col gap-[15px]">
    {works.map(work => (
      <div class="flex bg-white/3 border border-glass-border p-[15px] rounded-xl gap-5 transition-all duration-300 hover:border-accent hover:bg-white/5 max-md:p-3 max-md:gap-3.75">
        <img src={work.cover || "https://via.placeholder.com/150x225"} alt={work.title} class="w-20 max-md:w-[60px] aspect-[2/3] object-cover rounded-md border border-white/10" />
        
        <div class="flex-1 flex flex-col justify-center">
          <h3 class="text-[1.1rem] max-md:text-[0.95rem] mb-1 font-serif">{work.title}</h3>
          <div class="text-[0.75rem] opacity-50 flex flex-col gap-1">
            {work.type === 'book' ? (
              <span class="text-accent font-bold">{work.chaptersCount} Chapters</span>
            ) : (
              <span class="text-[#44ff44] font-bold">Single Piece</span>
            )}
            <span>{new Date(work.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            <span class={`px-3 py-1 rounded-full text-[0.65rem] font-bold uppercase w-fit mt-1 bg-white/10 ${work.status === 'published' ? 'bg-green-500/10 text-green-400' : 'bg-orange-500/10 text-orange-400'}`}>
              {work.status.toUpperCase()}
            </span>
          </div>
        </div>

        <div class="flex flex-col justify-center min-w-[150px] max-md:min-w-0">
          <a href={`/admin/works/${work.id}`} class="bg-white/5 text-white border border-glass-border px-5 py-3 rounded-lg font-bold text-[0.8rem] text-center no-underline transition-all duration-300 hover:bg-white/10 max-md:p-2.5 max-md:text-[0.7rem]">Manage Work</a>
        </div>
      </div>
    ))}
    {works.length === 0 && (
      <div class="text-center py-[100px] opacity-30 col-span-full">
        <p>No works found in the archive yet.</p>
      </div>
    )}
  </div>
</AdminLayout>
