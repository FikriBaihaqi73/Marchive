---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/index';
import { categories as categoryTable, works as worksTable } from '@db/schema';
import { eq } from 'drizzle-orm';
import RichTextEditor from '../../../components/admin/RichTextEditor.astro';
import { uploadImage } from '../../../lib/cloudinary';

const type = Astro.url.searchParams.get('type') || 'book';
const isSingle = type === 'single';

let error = '';

// Handle Form Submission
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const title = data.get('title')?.toString();
    const categoryId = parseInt(data.get('categoryId')?.toString() || '0');
    const coverFile = data.get('cover') as File;
    const synopsis = data.get('synopsis')?.toString();
    const content = data.get('content')?.toString(); // Content from Rich Text Editor

    if (title && categoryId) {
      let coverUrl = '';
      
      // Upload to Cloudinary if file exists
      if (coverFile && coverFile.size > 0) {
        try {
          coverUrl = await uploadImage(coverFile, 'marchive/covers');
        } catch (uploadErr) {
          console.error('Upload Error:', uploadErr);
          error = 'Failed to upload image. Please check your Cloudinary config.';
        }
      }

      if (!error) {
        const slug = title.toLowerCase().replace(/ /g, '-').replace(/[^\w-]+/g, '');
        
        const [newWork] = await db.insert(worksTable).values({
          title,
          slug,
          categoryId,
          type: isSingle ? 'single' : 'book',
          cover: coverUrl,
          synopsis: isSingle ? null : synopsis,
          content: isSingle ? content : null,
          status: 'draft', // Default to draft
        }).returning();

        return Astro.redirect('/admin/works');
      }
    } else {
      error = 'Title and Category are required.';
    }
  } catch (e) {
    error = 'Failed to save work. Please check your data.';
    console.error(e);
  }
}

// Fetch real categories from database
const allCategories = await db.select().from(categoryTable);
const filteredCategories = allCategories.filter(cat => cat.type === (isSingle ? 'single' : 'book'));
---

<AdminLayout title={isSingle ? "Create Single Piece" : "Start New Book"} activePage="new-work">
  <div class="max-w-[900px]" data-type={type} id="creation-container">
    {error && (
      <div class="bg-red-500/10 text-red-500 p-[15px] rounded-lg mb-[30px] border border-red-500/20 text-[0.85rem]">
        {error}
      </div>
    )}

    <form class="flex flex-col gap-6" method="POST" id="main-form" enctype="multipart/form-data">
      <!-- Hidden input for Rich Text content -->
      <input type="hidden" name="content" id="hidden-content" />
      
      <div class="flex flex-col gap-2">
        <label for="title" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">{isSingle ? "TITLE OF YOUR PIECE" : "BOOK TITLE"}</label>
        <input type="text" id="title" name="title" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[1.1rem] font-serif focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all placeholder:opacity-20" placeholder={isSingle ? "e.g. Midnight Sonnet" : "e.g. Chronicles of Marchive"} required />
      </div>

      <div class="flex flex-col gap-2">
        <label for="category" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CATEGORY</label>
        <select id="category" name="categoryId" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all appearance-none cursor-pointer">
          {filteredCategories.map(cat => (
            <option value={cat.id} class="bg-[#0a0a0a]">{cat.name}</option>
          ))}
          {filteredCategories.length === 0 && (
            <option disabled class="bg-[#0a0a0a]">No categories found for this type</option>
          )}
        </select>
      </div>


      <!-- SINGLE PIECE EDITOR -->
      <div id="single-editor-area" style={isSingle ? "display: block;" : "display: none;"}>
        <div class="flex flex-col gap-2">
          <label class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CONTENT (YOUR WORK)</label>
          <RichTextEditor placeholder="Tuliskan baris puisi atau narasi karya Anda di sini..." />
        </div>
      </div>

      <!-- BOOK SYNOPSIS AREA -->
      <div id="book-metadata-area" style={isSingle ? "display: none;" : "display: block;"}>
        <div class="flex flex-col gap-2">
          <label for="synopsis" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">SYNOPSIS / DESCRIPTION</label>
          <textarea id="synopsis" name="synopsis" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all placeholder:opacity-20 resize-none" rows="6" placeholder="What is this book about?"></textarea>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label for="cover" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">COVER IMAGE (UPLOAD TO CLOUDINARY)</label>
        <div class="relative group">
          <input type="file" id="cover" name="cover" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onchange="const name = this.files[0]?.name; if(name) document.getElementById('file-name').textContent = name;" />
          <div class="bg-white/5 border border-white/10 border-dashed rounded-lg p-[30px] text-center transition-all group-hover:border-accent/50 group-hover:bg-white/10">
            <span id="file-name" class="text-[0.9rem] opacity-40 tracking-[0.1em]">CLICK TO SELECT OR DRAG IMAGE HERE</span>
          </div>
        </div>
      </div>

      <div class="flex gap-5 items-center mt-10 pt-[30px] border-t border-white/5">
        <button type="submit" class="bg-accent text-black px-10 py-4 rounded-lg font-bold text-[0.85rem] tracking-[0.1em] transition-all hover:scale-105 active:scale-95 cursor-pointer disabled:opacity-50 disabled:cursor-wait" id="submit-btn">
          {isSingle ? "PUBLISH PIECE" : "CREATE BOOK"}
        </button>
        <a href="/admin/works" class="text-white opacity-50 no-underline text-[0.8rem] hover:opacity-100 hover:text-accent transition-all">Cancel</a>
      </div>
    </form>
  </div>

  <script is:inline>
    // 1. UI Toggling (Single vs Book)
    const urlParams = new URLSearchParams(window.location.search);
    const type = urlParams.get('type');
    
    if (type === 'single') {
      document.getElementById('single-editor-area').style.display = 'block';
      document.getElementById('book-metadata-area').style.display = 'none';
      document.getElementById('submit-btn').innerText = 'PUBLISH PIECE';
    }

    // 2. Sync Quill Content on Submit
    const form = document.getElementById('main-form');
    const hiddenInput = document.getElementById('hidden-content');

    form?.addEventListener('submit', (e) => {
      // 2. Disable button to show loading
      const btn = document.getElementById('submit-btn');
      if (btn) {
        btn.disabled = true;
        btn.innerText = 'UPLOADING...';
      }

      // 3. Access global Quill instance (defined in RichTextEditor component)
      if (window.quill) {
        hiddenInput.value = window.quill.root.innerHTML;
        console.log('Syncing content:', hiddenInput.value);
      }
    });
  </script>
</AdminLayout>


