---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/index';
import { categories as categoryTable, works as worksTable } from '@schema/index';
import { eq, count } from 'drizzle-orm';

const { id } = Astro.params;
const catId = parseInt(id || '0');

// 1. Fetch current category
const [category] = await db.select().from(categoryTable).where(eq(categoryTable.id, catId)).limit(1);

if (!category) return Astro.redirect('/admin/categories');

let error = '';
let success = '';

// 2. Handle POST Actions
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action')?.toString();

    if (action === 'delete') {
      // Safety check: Don't delete if works exist
      const [{ count: workCount }] = await db
        .select({ count: count(worksTable.id) })
        .from(worksTable)
        .where(eq(worksTable.categoryId, catId));

      if (workCount > 0) {
        error = `Cannot delete category. It is currently being used by ${workCount} works.`;
      } else {
        await db.delete(categoryTable).where(eq(categoryTable.id, catId));
        return Astro.redirect('/admin/categories');
      }
    } else {
      const name = data.get('name')?.toString();
      const type = data.get('type')?.toString();
      const slug = data.get('slug')?.toString();
      const description = data.get('description')?.toString();

      if (name && type && slug) {
        await db.update(categoryTable)
          .set({ name, type, slug, description })
          .where(eq(categoryTable.id, catId));

        success = 'Category updated successfully!';
      } else {
        error = 'Name, Type, and Slug are required.';
      }
    }
  } catch (e) {
    error = 'Failed to process request.';
    console.error(e);
  }
}
---


<AdminLayout title={`Edit Category: ${category.name}`} activePage="categories">
  <div class="max-w-[600px]">
    <div class="mb-[50px]">
      <a href="/admin/categories" class="text-[0.7rem] tracking-[0.1em] opacity-50 no-underline mb-[15px] block hover:opacity-100 hover:text-accent">&larr; BACK TO LIST</a>
      <h1 class="text-[2.5rem] font-serif leading-tight">Edit Category</h1>
    </div>

    {error && <div class="bg-red-500/10 text-red-500 p-[15px] rounded-lg mb-[30px] border border-red-500/20 text-[0.85rem]">{error}</div>}
    {success && <div class="bg-green-500/10 text-green-400 p-[15px] rounded-lg mb-[30px] border border-green-500/20 text-[0.85rem]">{success}</div>}

    <form class="flex flex-col gap-6" method="POST" id="edit-category-form">
      <input type="hidden" name="action" id="form-action" value="update" />
      <div class="flex flex-col gap-2">
        <label for="name" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CATEGORY NAME</label>
        <input type="text" id="name" name="name" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all" value={category.name} required />
      </div>

      <div class="flex flex-col gap-2">
        <label for="type" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CONTENT TYPE</label>
        <select id="type" name="type" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all appearance-none cursor-pointer" required>
          <option value="book" selected={category.type === 'book'} class="bg-[#0a0a0a]">Book / Series</option>
          <option value="single" selected={category.type === 'single'} class="bg-[#0a0a0a]">Single Piece</option>
        </select>
      </div>

      <div class="flex flex-col gap-2">
        <label for="slug" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">URL SLUG</label>
        <input type="text" id="slug" name="slug" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all" value={category.slug} required />
      </div>

      <div class="flex flex-col gap-2">
        <label for="description" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">DESCRIPTION</label>
        <textarea id="description" name="description" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all resize-none" rows="4">{category.description}</textarea>
      </div>

      <div class="mt-10 flex gap-[15px]">
        <button type="submit" class="bg-accent text-black px-8 py-4 rounded-lg font-bold text-[0.8rem] tracking-[0.1em] transition-all hover:scale-105 active:scale-95 cursor-pointer">SAVE CHANGES</button>
        <button type="button" class="bg-transparent text-red-500 border border-red-500 px-8 py-4 rounded-lg font-bold text-[0.8rem] tracking-[0.1em] hover:bg-red-500 hover:text-black transition-all cursor-pointer" id="delete-btn">DELETE CATEGORY</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script is:inline>
  const form = document.getElementById('edit-category-form');
  const actionInput = document.getElementById('form-action');

  // Delete Category
  document.getElementById('delete-btn')?.addEventListener('click', () => {
    if (confirm('Are you sure you want to delete this category? This cannot be undone.')) {
      if (actionInput && form) {
        actionInput.value = 'delete';
        form.submit();
      }
    }
  });
</script>

