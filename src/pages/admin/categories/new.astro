---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/index';
import { categories as categoryTable } from '@db/schema';

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const name = data.get('name')?.toString();
    const type = data.get('type')?.toString();
    const slugInput = data.get('slug')?.toString();
    const description = data.get('description')?.toString();

    if (name && type) {
      const slug = slugInput || name.toLowerCase().replace(/ /g, '-').replace(/[^\w-]+/g, '');
      
      await db.insert(categoryTable).values({
        name,
        type,
        slug,
        description
      });

      return Astro.redirect('/admin/categories');
    } else {
      error = 'Name and Type are required.';
    }
  } catch (e) {
    error = 'Failed to create category. Slug might already exist.';
    console.error(e);
  }
}
---


<AdminLayout title="Add New Category" activePage="categories">
  <div class="max-w-[600px]">
    {error && (
      <div class="bg-red-500/10 text-red-500 p-[15px] rounded-lg mb-[30px] border border-red-500/20 text-[0.85rem]">
        {error}
      </div>
    )}

    <form class="flex flex-col gap-6" method="POST">
      <div class="flex flex-col gap-2">
        <label for="name" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CATEGORY NAME</label>
        <input type="text" id="name" name="name" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all placeholder:opacity-20" placeholder="e.g. Science Fiction" required />
      </div>

      <div class="flex flex-col gap-2">
        <label for="type" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">CONTENT TYPE</label>
        <select id="type" name="type" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all appearance-none cursor-pointer" required>
          <option value="book" class="bg-[#0a0a0a]">Book / Series (Multi-chapters)</option>
          <option value="single" class="bg-[#0a0a0a]">Single Piece (Poem, Design, etc.)</option>
        </select>
        <p class="text-[0.7rem] opacity-50 mt-2 ml-1">This determines where the category appears when creating new content.</p>
      </div>

      <div class="flex flex-col gap-2">
        <label for="slug" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">URL SLUG (OPTIONAL)</label>
        <input type="text" id="slug" name="slug" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all placeholder:opacity-20" placeholder="e.g. sci-fi" />
      </div>

      <div class="flex flex-col gap-2">
        <label for="description" class="text-[0.65rem] tracking-[0.2em] font-bold opacity-40 uppercase ml-1">DESCRIPTION</label>
        <textarea id="description" name="description" class="bg-white/5 border border-white/10 rounded-lg p-[15px_20px] text-white text-[0.9rem] focus:outline-none focus:border-accent/50 focus:bg-white/10 transition-all placeholder:opacity-20 resize-none" rows="3" placeholder="Briefly describe this category..."></textarea>
      </div>

      <div class="flex gap-[15px] mt-10">
        <button type="submit" class="bg-accent text-black px-8 py-4 rounded-lg font-bold text-[0.8rem] tracking-[0.1em] transition-all hover:scale-105 active:scale-95 cursor-pointer">CREATE CATEGORY</button>
        <a href="/admin/categories" class="bg-transparent text-white border border-glass-border px-8 py-4 rounded-lg font-bold text-[0.8rem] tracking-[0.1em] no-underline hover:bg-white/5 transition-all">CANCEL</a>
      </div>
    </form>
  </div>
</AdminLayout>
