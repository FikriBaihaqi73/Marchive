---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/index';
import { categories as categoryTable, works as worksTable } from '@schema/index';
import { count, eq } from 'drizzle-orm';

// Fetch real categories with work counts
const categories = await Promise.all((await db.select().from(categoryTable)).map(async (cat) => {
  const [{ count: worksCount }] = await db
    .select({ count: count(worksTable.id) })
    .from(worksTable)
    .where(eq(worksTable.categoryId, cat.id));
  
  return { ...cat, worksCount };
}));
---

<AdminLayout title="Category Management" activePage="categories">
  <div class="works-list-header">
    <div class="header-left">
      <p>Organize your gallery by creating and managing categories.</p>
    </div>
    <a href="/admin/categories/new" class="btn-primary">+ New Category</a>
  </div>

  <div class="category-grid">
    {categories.map(cat => (
      <div class="category-card">
        <div class="cat-info">
          <div class="cat-type-badge">{cat.type.toUpperCase()}</div>
          <h3>{cat.name}</h3>
          <p>{cat.description}</p>
        </div>
        
        <div class="cat-footer">
          <span class="work-count"><strong>{cat.worksCount}</strong> items</span>
          <a href={`/admin/categories/${cat.id}/edit`} class="btn-edit">Edit Settings</a>
        </div>
      </div>
    ))}
  </div>
</AdminLayout>
