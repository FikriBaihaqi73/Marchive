---
import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/index';
import { works as worksTable, categories as categoryTable, chapters as chaptersTable } from '@schema/index';
import { count, eq } from 'drizzle-orm';

// Fetch Real Stats
const [totalWorks] = await db.select({ value: count() }).from(worksTable);
const [totalChapters] = await db.select({ value: count() }).from(chaptersTable);
const [totalCategories] = await db.select({ value: count() }).from(categoryTable);
const [totalBooks] = await db.select({ value: count() }).from(worksTable).where(eq(worksTable.type, 'book'));
const [totalSingles] = await db.select({ value: count() }).from(worksTable).where(eq(worksTable.type, 'single'));

const stats = [
  { label: 'Total Works', value: totalWorks.value.toString() },
  { label: 'Books/Series', value: totalBooks.value.toString() },
  { label: 'Single Pieces', value: totalSingles.value.toString() },
  { label: 'Total Chapters', value: totalChapters.value.toString() },
  { label: 'Categories', value: totalCategories.value.toString() },
];
---


<AdminLayout title="Dashboard Overview" activePage="dashboard">
  <section class="grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-[25px]">
    {stats.map(stat => (
      <div class="bg-white/3 border border-glass-border p-[30px] rounded-xl transition-all duration-300 hover:border-accent hover:-translate-y-1">
        <span class="text-[0.7rem] tracking-[0.15em] opacity-50 uppercase mb-2.5 block">{stat.label}</span>
        <span class="text-[2.5rem] font-bold text-accent">{stat.value}</span>
      </div>
    ))}
  </section>

  <section class="mt-[60px]">
    <h2 class="font-serif mb-[30px] text-2xl uppercase tracking-wider">Quick Actions</h2>
    <div class="flex flex-wrap gap-5">
      <a href="/admin/works/new" class="bg-accent text-black px-[30px] py-[15px] font-bold tracking-[0.1em] rounded-lg no-underline transition-all duration-300 hover:scale-105">Create New Work</a>
      <a href="/admin/categories" class="bg-white/5 text-white border border-glass-border px-[30px] py-[15px] font-bold tracking-[0.1em] rounded-lg no-underline transition-all duration-300 hover:bg-white/10">Manage Categories</a>
    </div>
  </section>
</AdminLayout>
