---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { users } from '../../db/schema';
import { eq } from 'drizzle-orm';
import bcrypt from 'bcryptjs';

// We get the user ID from the middleware context locals (or decode it again)
const userPayload = Astro.locals.user as any;
const userId = userPayload?.id;

let message = '';
let isError = false;

if (!userId) {
  return Astro.redirect('/login');
}

// Fetch current user
const [currentUser] = await db.select().from(users).where(eq(users.id, userId)).limit(1);

if (!currentUser) {
  // Should not happen unless DB is reset while logged in
  Astro.cookies.delete('marchive_auth_token', { path: '/' });
  return Astro.redirect('/login');
}

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const newUsername = data.get('username')?.toString() || '';
    const newPassword = data.get('password')?.toString() || '';

    if (!newUsername || newUsername.trim() === '') {
      isError = true;
      message = 'Username cannot be empty.';
    } else {
      const updateData: any = { username: newUsername };
      
      if (newPassword && newPassword.trim() !== '') {
        const hashedPassword = await bcrypt.hash(newPassword, 10);
        updateData.password = hashedPassword;
      }

      await db.update(users).set(updateData).where(eq(users.id, userId));
      
      isError = false;
      message = 'Admin credentials updated successfully.';
      
      // Update local variable for view
      currentUser.username = newUsername;
    }
  } catch (err: any) {
    isError = true;
    message = 'Error updating credentials. Username might already be taken.';
    console.error(err);
  }
}
---

<AdminLayout title="System Settings" activePage="settings">
  <section class="max-w-xl">
    <div class="bg-white/5 border border-glass-border rounded-xl p-8">
      <h2 class="text-xl font-bold mb-6 text-white font-serif">Admin Credentials</h2>
      <p class="text-gray-400 text-sm mb-8">Update your login username and password. If you don't want to change the password, leave the password field blank.</p>

      {message && (
        <div class={`mb-6 p-4 rounded-lg text-sm tracking-wide ${isError ? 'bg-red-500/10 text-red-400 border border-red-500/20' : 'bg-green-500/10 text-green-400 border border-green-500/20'}`}>
          {message}
        </div>
      )}

      <form method="POST" class="space-y-6">
        <div>
          <label for="username" class="block text-[0.65rem] tracking-[0.2em] uppercase font-bold text-gray-500 mb-2">Username</label>
          <input 
            type="text" 
            id="username" 
            name="username" 
            value={currentUser.username} 
            required 
            class="w-full bg-black/50 border border-gray-800 rounded-lg p-3 text-white focus:outline-none focus:border-accent transition-colors"
          />
        </div>

        <div>
          <label for="password" class="block text-[0.65rem] tracking-[0.2em] uppercase font-bold text-gray-500 mb-2">New Password (Optional)</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            placeholder="Leave blank to keep current password" 
            class="w-full bg-black/50 border border-gray-800 rounded-lg p-3 text-white focus:outline-none focus:border-accent transition-colors placeholder:text-gray-700"
          />
        </div>

        <div class="pt-4 border-t border-gray-800">
          <button type="submit" class="bg-accent text-black font-bold uppercase tracking-widest text-[0.75rem] px-6 py-3 rounded-lg hover:bg-white transition-colors">
            Save Changes
          </button>
        </div>
      </form>
    </div>
  </section>
</AdminLayout>
