---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { works as worksTable, categories as categoryTable, chapters as chaptersTable } from '../../db/schema';
import { eq, asc } from 'drizzle-orm';

const { id } = Astro.params;

// 1. Fetch work details joined with category
const [work] = await db
  .select({
    id: worksTable.id,
    title: worksTable.title,
    cover: worksTable.cover,
    synopsis: worksTable.synopsis,
    content: worksTable.content,
    type: worksTable.type,
    createdAt: worksTable.createdAt,
    categoryName: categoryTable.name,
  })
  .from(worksTable)
  .leftJoin(categoryTable, eq(worksTable.categoryId, categoryTable.id))
  .where(eq(worksTable.id, parseInt(id || '0')))
  .limit(1);

if (!work) return Astro.redirect('/404');

// 2. Fetch chapters if it's a book
let chapters: any[] = [];
if (work.type === 'book') {
  chapters = await db
    .select()
    .from(chaptersTable)
    .where(eq(chaptersTable.workId, work.id))
    .orderBy(asc(chaptersTable.order));
}

const formattedDate = new Date(work.createdAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---


<Layout>
  <main class="detail-page container">
    <script>
      document.getElementById('back-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        const referrer = document.referrer;
        // Jika kembali dari halaman baca (chapter), arahkan ke /works agar tidak looping
        if (referrer.includes(window.location.pathname + '/')) {
          window.location.href = '/works';
        } else if (referrer.includes(window.location.origin)) {
          history.back();
        } else {
          window.location.href = '/works';
        }
      });
    </script>

    <div class="navigation-top">
      <a href="#" id="back-btn" class="back-link">&larr; BACK</a>
      <div class="meta-tag">{work.categoryName || 'UNCATEGORIZED'}</div>
    </div>

    <div class="detail-grid">
      <!-- Title and Main Info -->
      <header class="detail-header">
        <h1 class="fade-in">{work.title}</h1>
        <div class="work-date fade-in">{formattedDate}</div>
      </header>

      <div class="visual-pane fade-in">
        <img src={work.cover || "https://via.placeholder.com/600x800"} alt={work.title} class="main-cover" />
      </div>

      <div class="content-pane fade-in">
        {work.type === 'book' ? (
          <div class="content-book">
            <section class="synopsis">
              <h2>SYNOPSIS</h2>
              <p>{work.synopsis || "No synopsis available."}</p>
            </section>
            
            <section class="chapters-grid">
              <h2>CHAPTERS</h2>
              <div class="chapters-list">
                {chapters.map((chapter) => (
                  <a href={`/works/${work.id}/${chapter.slug || chapter.id}`} class="chapter-card">
                    <span class="ch-num">CH {chapter.order}</span>
                    <h3>{chapter.title}</h3>
                    <span class="read-btn">READ &rarr;</span>
                  </a>
                ))}
                {chapters.length === 0 && (
                  <p style="opacity: 0.5; font-size: 0.85rem;">No chapters published yet.</p>
                )}
              </div>
            </section>
          </div>
        ) : (
          <div class="content-standard">
            <div class="main-body ql-editor" set:html={work.content}>
            </div>
            {work.categoryName === 'Puisi' && <div class="poetry-end"></div>}
          </div>
        )}
      </div>
    </div>

  </main>
</Layout>

<style>
  .detail-page {
    padding-top: 150px;
    padding-bottom: 150px;
  }

  .navigation-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 60px;
    border-bottom: 1px solid var(--glass-border);
    padding-bottom: 20px;
  }

  .back-link {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    font-weight: 600;
    opacity: 0.6;
  }

  .back-link:hover {
    opacity: 1;
    color: var(--accent-color);
  }

  .meta-tag {
    font-size: 0.75rem;
    background: var(--accent-color);
    color: #000;
    padding: 6px 16px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: inline-block;
    line-height: 1;
  }

  .detail-header {
    grid-column: 1 / -1;
    margin-bottom: 80px;
    text-align: center;
  }

  h1 {
    font-size: 5rem;
    margin-bottom: 10px;
  }

  .work-date {
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    opacity: 0.5;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 80px;
    align-items: start;
  }

  .main-cover {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    border: 1px solid var(--glass-border);
  }

  /* Book Layout */
  .synopsis {
    margin-bottom: 60px;
  }

  .synopsis h2, .chapters-grid h2 {
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--accent-color);
    margin-bottom: 30px;
    border-bottom: 1px solid var(--glass-border);
    padding-bottom: 10px;
    width: fit-content;
  }

  .synopsis p {
    font-size: 1.1rem;
    line-height: 1.8;
    opacity: 0.8;
  }

  .chapters-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .chapter-card {
    padding: 30px;
    border: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.02);
  }

  .chapter-card:hover {
    border-color: var(--accent-color);
    background: rgba(197, 160, 89, 0.05);
    transform: translateX(10px);
  }

  .ch-num {
    font-size: 0.7rem;
    opacity: 0.4;
    font-weight: 800;
  }

  .chapter-card h3 {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 1rem;
    flex-grow: 1;
    margin-left: 40px;
  }

  .read-btn {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    opacity: 0.6;
  }

  /* Standard Content Layout */
  .main-body {
    font-size: 1.25rem;
    line-height: 2;
    white-space: pre-line;
    opacity: 0.9;
    font-style: italic;
  }

  .poetry-end {
    width: 40px;
    height: 1px;
    background: var(--accent-color);
    margin-top: 60px;
  }

  @media (max-width: 992px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }
    h1 {
      font-size: 3rem;
    }
  }
</style>
