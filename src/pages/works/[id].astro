---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { works as worksTable, categories as categoryTable, chapters as chaptersTable } from '../../db/schema';
import { eq, asc } from 'drizzle-orm';

const { id } = Astro.params;

// 1. Fetch work details joined with category
const [work] = await db
  .select({
    id: worksTable.id,
    title: worksTable.title,
    cover: worksTable.cover,
    synopsis: worksTable.synopsis,
    content: worksTable.content,
    type: worksTable.type,
    createdAt: worksTable.createdAt,
    categoryName: categoryTable.name,
  })
  .from(worksTable)
  .leftJoin(categoryTable, eq(worksTable.categoryId, categoryTable.id))
  .where(eq(worksTable.id, parseInt(id || '0')))
  .limit(1);

if (!work) return Astro.redirect('/404');

// 2. Fetch chapters if it's a book
let chapters: any[] = [];
if (work.type === 'book') {
  chapters = await db
    .select()
    .from(chaptersTable)
    .where(eq(chaptersTable.workId, work.id))
    .orderBy(asc(chaptersTable.order));
}

const formattedDate = new Date(work.createdAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---


<Layout>
  <main class="pt-[150px] pb-[150px] container">
    <script>
      document.getElementById('back-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        const referrer = document.referrer;
        // Jika kembali dari halaman baca (chapter), arahkan ke /works agar tidak looping
        if (referrer.includes(window.location.pathname + '/')) {
          window.location.href = '/works';
        } else if (referrer.includes(window.location.origin)) {
          history.back();
        } else {
          window.location.href = '/works';
        }
      });
    </script>

    <div class="flex justify-between items-center mb-[60px] border-b border-glass-border pb-5">
      <a href="#" id="back-btn" class="text-[0.7rem] tracking-[0.1em] font-semibold opacity-60 no-underline transition-all duration-300 hover:opacity-100 hover:text-accent">&larr; BACK</a>
      <div class="text-[0.75rem] bg-accent text-black px-4 py-1.5 font-bold tracking-[0.15em] uppercase leading-none">{work.categoryName || 'UNCATEGORIZED'}</div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr,1.5fr] gap-20 items-start">
      <!-- Title and Main Info -->
      <header class="col-span-full mb-20 text-center">
        <h1 class="text-[3rem] lg:text-[5rem] mb-2.5 fade-in">{work.title}</h1>
        <div class="text-[0.8rem] tracking-[0.3em] opacity-50 fade-in uppercase">{formattedDate}</div>
      </header>

      <div class="fade-in">
        <img src={work.cover || "https://via.placeholder.com/600x800"} alt={work.title} class="w-full aspect-square object-cover border border-glass-border" />
      </div>

      <div class="fade-in">
        {work.type === 'book' ? (
          <div>
            <section class="mb-[60px]">
              <h2 class="text-[0.8rem] tracking-[0.2em] text-accent mb-[30px] border-b border-glass-border pb-2.5 w-fit uppercase font-serif">SYNOPSIS</h2>
              <p class="text-[1.1rem] leading-[1.8] opacity-80">{work.synopsis || "No synopsis available."}</p>
            </section>
            
            <section>
              <h2 class="text-[0.8rem] tracking-[0.2em] text-accent mb-[30px] border-b border-glass-border pb-2.5 w-fit uppercase font-serif">CHAPTERS</h2>
              <div class="flex flex-col gap-5">
                {chapters.map((chapter) => (
                  <a href={`/works/${work.id}/${chapter.slug || chapter.id}`} class="p-[30px] border border-glass-border flex items-center justify-between transition-all duration-300 no-underline text-inherit bg-white/2 hover:border-accent hover:bg-accent/5 hover:translate-x-2.5 group">
                    <span class="text-[0.7rem] opacity-40 font-extrabold uppercase">CH {chapter.order}</span>
                    <h3 class="font-sans font-medium text-[1rem] flex-grow ml-10">{chapter.title}</h3>
                    <span class="text-[0.7rem] font-bold tracking-[0.1em] opacity-60 group-hover:opacity-100">READ &rarr;</span>
                  </a>
                ))}
                {chapters.length === 0 && (
                  <p class="opacity-50 text-[0.85rem]">No chapters published yet.</p>
                )}
              </div>
            </section>
          </div>
        ) : (
          <div class="content-standard">
            <div class="text-[1.25rem]! leading-[2]! whitespace-pre-line opacity-90! italic ql-editor" set:html={work.content}>
            </div>
            {work.categoryName === 'Puisi' && <div class="w-10 h-[1px] bg-accent mt-[60px]"></div>}
          </div>
        )}
      </div>
    </div>
  </main>
