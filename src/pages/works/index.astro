---
import Layout from '../../layouts/Layout.astro';
import GalleryItem from '../../components/GalleryItem.astro';
import { works } from '../../data/works';
---

<Layout>
  <main class="works-page container">
    <header class="page-header">
      <div class="section-num">ARCHIVE</div>
      <h1>ALL WORKS</h1>
      <p class="subtitle text-muted">Exploration of thoughts, literature, and visual arts.</p>
    </header>

    <div class="filter-bar">
      <button class="filter-item active">ALL</button>
      <button class="filter-item">NOVEL</button>
      <button class="filter-item">PUISI</button>
      <button class="filter-item">CERPEN</button>
      <button class="filter-item">ESAI</button>
      <button class="filter-item">DESAIN</button>
      <button class="filter-item">CATATAN</button>
    </div>

    <div class="gallery-grid-new">
      {works.map((work) => (
        <GalleryItem {...work} />
      ))}
    </div>
  </main>
</Layout>

<style>
  .works-page {
    padding-top: 180px;
    padding-bottom: 120px;
  }

  .page-header {
    margin-bottom: 80px;
    text-align: center;
  }

  h1 {
    font-size: 5rem;
    margin-bottom: 20px;
  }

  .subtitle {
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .filter-bar {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-bottom: 80px;
    border-bottom: 1px solid var(--glass-border);
    padding-bottom: 20px;
  }

  .filter-item {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    opacity: 0.4;
    transition: opacity 0.3s;
  }

  .filter-item.active, .filter-item:hover {
    opacity: 1;
    color: var(--accent-color);
  }

  .gallery-grid-new {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
  }

  @media (max-width: 992px) {
    h1 { font-size: 3rem; }
    .filter-bar { gap: 20px; overflow-x: auto; justify-content: flex-start; }
  }
</style>
<script>
  function initFilters() {
    const filterButtons = document.querySelectorAll('.filter-item');
    const galleryItems = document.querySelectorAll('.gallery-item-new');

    function applyFilter(category: string) {
      const lowerCat = category.toLowerCase();
      
      // Update buttons
      filterButtons.forEach(btn => {
        if (btn.textContent?.toLowerCase() === lowerCat) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Update items
      galleryItems.forEach(item => {
        const itemCat = (item as HTMLElement).dataset.category;
        if (lowerCat === 'all' || itemCat === lowerCat) {
          (item as HTMLElement).style.display = 'block';
          setTimeout(() => (item as HTMLElement).style.opacity = '1', 10);
        } else {
          (item as HTMLElement).style.opacity = '0';
          setTimeout(() => (item as HTMLElement).style.display = 'none', 300);
        }
      });
    }

    // Listen for clicks
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.textContent || 'ALL';
        applyFilter(cat);
        // Update URL without refresh
        const newUrl = cat.toLowerCase() === 'all' ? '/works' : `/works?filter=${cat.toLowerCase()}`;
        window.history.pushState({}, '', newUrl);
      });
    });

    // Check URL params on load
    const params = new URLSearchParams(window.location.search);
    const initialFilter = params.get('filter');
    if (initialFilter) {
      applyFilter(initialFilter);
    }
  }

  // Run on load
  initFilters();
</script>
