---
import Layout from '@layouts/Layout.astro';
import GalleryItem from '@components/GalleryItem.astro';
import { db } from '@db/index';
import { works as worksTable, categories as categoryTable } from '@schema/index';
import { desc, eq } from 'drizzle-orm';

// 1. Fetch Categories for Filters
const dbCategories = await db.select().from(categoryTable);

// 2. Fetch All Published Works with Category Names
const allWorks = await db
  .select({
    id: worksTable.id,
    title: worksTable.title,
    cover: worksTable.cover,
    type: worksTable.type,
    status: worksTable.status,
    category: categoryTable.name,
    createdAt: worksTable.createdAt,
  })
  .from(worksTable)
  .leftJoin(categoryTable, eq(worksTable.categoryId, categoryTable.id))
  .where(eq(worksTable.status, 'published'))
  .orderBy(desc(worksTable.createdAt));
---


<Layout>
  <main class="pt-[180px] max-lg:pt-[120px] pb-[120px] container">
    <header class="mb-20 text-center">
      <div class="flex items-center gap-[15px] justify-center text-[0.9rem] font-medium mb-5">ARCHIVE</div>
      <h1 class="text-[3rem] lg:text-[5rem] mb-5 tracking-[0.1em]">ALL WORKS</h1>
      <p class="text-[0.9rem] tracking-[0.2em] uppercase opacity-60">Exploration of thoughts, literature, and visual arts.</p>
    </header>

    <!-- Desktop Filter Bar -->
    <div class="hidden lg:flex justify-center gap-10 mb-20 border-b border-glass-border pb-5">
      <button class="filter-item text-[0.75rem] tracking-[0.15em] opacity-40 transition-all duration-300 hover:opacity-100 hover:text-accent [&.active]:opacity-100 [&.active]:text-accent" data-category="ALL">ALL</button>
      {dbCategories.map(cat => (
        <button class="filter-item text-[0.75rem] tracking-[0.15em] opacity-40 transition-all duration-300 hover:opacity-100 hover:text-accent [&.active]:opacity-100 [&.active]:text-accent" data-category={cat.name.toUpperCase()}>{cat.name.toUpperCase()}</button>
      ))}
    </div>

    <!-- Mobile Floating Filter -->
    <div class="lg:hidden mb-10 relative">
      <button id="mobile-filter-trigger" class="flex items-center justify-center gap-3 bg-white/3 border border-glass-border p-[12px_20px] w-auto mx-auto text-white text-[0.65rem] tracking-[0.2em] font-bold">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 text-accent"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
        <span>FILTER ARCHIVE</span>
      </button>
      
      <div 
        id="mobile-filter-menu" 
        class="absolute top-[calc(100%+10px)] left-0 w-full bg-[#0f0f0ffc] backdrop-blur-[20px] border border-glass-border z-[500] p-[25px] opacity-0 invisible translate-y-2.5 transition-all duration-400 cubic-bezier-[0.165,0.84,0.44,1] [&.open]:opacity-100 [&.open]:visible [&.open]:translate-y-0"
      >
        <div class="flex justify-between items-center mb-[25px] pb-2.5 border-b border-white/5">
          <span class="text-[0.6rem] tracking-[0.2em] opacity-50 font-extrabold uppercase">SELECT CATEGORY</span>
          <button id="close-filter" class="text-2xl leading-none opacity-50">&times;</button>
        </div>
        <div class="grid grid-cols-2 gap-2.5">
          <button class="mobile-opt p-[15px] bg-white/2 border border-white/5 text-[0.65rem] text-center transition-all duration-300 [&.active]:bg-accent [&.active]:text-black" data-category="ALL">ALL</button>
          {dbCategories.map(cat => (
            <button class="mobile-opt p-[15px] bg-white/2 border border-white/5 text-[0.65rem] text-center transition-all duration-300 [&.active]:bg-accent [&.active]:text-black" data-category={cat.name.toUpperCase()}>{cat.name.toUpperCase()}</button>
          ))}
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-[15px] lg:gap-[30px]">
      {allWorks.map((work) => (
        <GalleryItem 
          id={work.id.toString()} 
          title={work.title} 
          category={work.category || 'Uncategorized'} 
          cover={work.cover || "https://via.placeholder.com/600x800"}
          date={new Date(work.createdAt).getFullYear().toString()}
        />
      ))}
      {allWorks.length === 0 && (
        <p class="col-span-full text-center opacity-50 py-[100px]">The archive is currently empty.</p>
      )}
    </div>

  </main>
</Layout>

<script>
  function initWorksFilters() {
    const trigger = document.getElementById('mobile-filter-trigger');
    const menu = document.getElementById('mobile-filter-menu');
    const closeBtn = document.getElementById('close-filter');
    const opts = document.querySelectorAll('.mobile-opt');
    const desktopBtns = document.querySelectorAll('.filter-item');
    const galleryItems = document.querySelectorAll('.gallery-item-new');

    function applyFilter(cat: string, updateUrl = true) {
      const lowerCat = cat.toLowerCase();
      
      // Update UI
      [...opts, ...desktopBtns].forEach(btn => {
        if ((btn as HTMLElement).dataset.category === cat) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Filter Gallery
      galleryItems.forEach(item => {
        const itemCat = (item as HTMLElement).dataset.category;
        if (lowerCat === 'all' || itemCat === lowerCat) {
          (item as HTMLElement).style.display = 'block';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });

      if (updateUrl) {
        const newUrl = lowerCat === 'all' ? '/works' : `/works?filter=${lowerCat}`;
        window.history.pushState({}, '', newUrl);
      }
    }

    trigger?.addEventListener('click', () => menu?.classList.add('open'));
    closeBtn?.addEventListener('click', () => menu?.classList.remove('open'));

    opts.forEach(opt => {
      opt.addEventListener('click', () => {
        const cat = (opt as HTMLElement).dataset.category || 'ALL';
        applyFilter(cat);
        menu?.classList.remove('open');
      });
    });

    desktopBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = (btn as HTMLElement).dataset.category || 'ALL';
        applyFilter(cat);
      });
    });

    // Check URL params on load
    const params = new URLSearchParams(window.location.search);
    const initialFilter = params.get('filter');
    if (initialFilter) {
      applyFilter(initialFilter.toUpperCase(), false);
    }
  }

  initWorksFilters();
</script>

<script>
  function initFilters() {
    const filterButtons = document.querySelectorAll('.filter-item');
    const galleryItems = document.querySelectorAll('.gallery-item-new');

    function applyFilter(category: string) {
      const lowerCat = category.toLowerCase();
      
      // Update buttons
      filterButtons.forEach(btn => {
        if (btn.textContent?.toLowerCase() === lowerCat) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Update items
      galleryItems.forEach(item => {
        const itemCat = (item as HTMLElement).dataset.category;
        if (lowerCat === 'all' || itemCat === lowerCat) {
          (item as HTMLElement).style.display = 'block';
          setTimeout(() => (item as HTMLElement).style.opacity = '1', 10);
        } else {
          (item as HTMLElement).style.opacity = '0';
          setTimeout(() => (item as HTMLElement).style.display = 'none', 300);
        }
      });
    }

    // Listen for clicks
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.textContent || 'ALL';
        applyFilter(cat);
        // Update URL without refresh
        const newUrl = cat.toLowerCase() === 'all' ? '/works' : `/works?filter=${cat.toLowerCase()}`;
        window.history.pushState({}, '', newUrl);
      });
    });

    // Check URL params on load
    const params = new URLSearchParams(window.location.search);
    const initialFilter = params.get('filter');
    if (initialFilter) {
      applyFilter(initialFilter);
    }
  }

  // Run on load
  initFilters();
</script>
