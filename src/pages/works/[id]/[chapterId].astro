---
import Layout from '../../../layouts/Layout.astro';
import { db } from '../../../db';
import { works as worksTable, chapters as chaptersTable } from '../../../db/schema';
import { eq, and, asc, desc, lt, gt } from 'drizzle-orm';

const { id, chapterId } = Astro.params;
const workId = parseInt(id || '0');

// 1. Fetch current chapter
const [chapter] = await db
  .select()
  .from(chaptersTable)
  .where(
    and(
      eq(chaptersTable.workId, workId),
      eq(chaptersTable.id, parseInt(chapterId || '0'))
    )
  )
  .limit(1);

if (!chapter) return Astro.redirect('/404');

// 2. Fetch parent work
const [work] = await db
  .select()
  .from(worksTable)
  .where(eq(worksTable.id, workId))
  .limit(1);

// 3. Navigation: Fetch Prev and Next Chapters
const [prevChapter] = await db
  .select()
  .from(chaptersTable)
  .where(
    and(
      eq(chaptersTable.workId, workId),
      lt(chaptersTable.order, chapter.order)
    )
  )
  .orderBy(desc(chaptersTable.order))
  .limit(1);

const [nextChapter] = await db
  .select()
  .from(chaptersTable)
  .where(
    and(
      eq(chaptersTable.workId, workId),
      gt(chaptersTable.order, chapter.order)
    )
  )
  .orderBy(asc(chaptersTable.order))
  .limit(1);
---


<Layout title={`${work.title} - ${chapter.title}`}>
  {/* Local Overrides to hide global elements for focus mode */}
  <style is:global>
    nav:not(.minimal-nav), footer { display: none !important; }
  </style>

  <div class="bg-[#050505] min-h-screen text-[#ccc] text-lg">
    
    <!-- Ultra Minimalist Top Bar -->
    <nav class="minimal-nav fixed top-0 left-0 w-full h-[60px] bg-[#050505] border-b border-white/5 z-[9999]">
      <div class="container h-full flex justify-between items-center relative">
        <a href={`/works/${work.id}`} class="flex items-center gap-2 text-[0.7rem] font-bold tracking-[0.1em] opacity-50 no-underline text-inherit hover:opacity-100 hover:text-accent transition-all">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          <span>BACK</span>
        </a>
        <div class="hidden sm:flex text-[0.75rem] tracking-[0.05em] uppercase gap-2.5 opacity-40">
          <span class="truncate max-w-[150px]">{work.title}</span>
          <span>/</span>
          <span class="text-accent opacity-100 font-bold truncate max-w-[200px]">{chapter.title}</span>
        </div>
        <div class="absolute bottom-0 left-0 w-full h-[2px] bg-white/5">
          <div class="h-full bg-accent w-0 transition-all duration-100" id="scroll-bar"></div>
        </div>
      </div>
    </nav>

    <main class="max-w-[680px]! mx-auto pt-[150px] pb-[100px] px-5">
      <article>
        <header class="text-center mb-20">
          <span class="text-[0.75rem] text-accent tracking-[0.4em] block mb-5 uppercase">CHAPTER {chapter.order}</span>
          <h1 class="text-[2.5rem] lg:text-[3.5rem] leading-[1.2] text-white font-serif">{chapter.title}</h1>
        </header>

        <section class="text-xl lg:text-[1.2rem] leading-[2.1] text-white/95 mb-[100px] font-serif ql-editor" set:html={chapter.content}>
        </section>

        <section class="pt-20 border-t border-white/5">
          {nextChapter ? (
            <div class="text-center">
              <span class="text-[0.7rem] tracking-[0.3em] opacity-40 block mb-5 uppercase">UP NEXT</span>
              <a href={`/works/${work.id}/${nextChapter.id}`} class="no-underline group">
                <h2 class="text-[2rem] lg:text-[2.5rem] font-serif text-accent mb-5 group-hover:underline">{nextChapter.title}</h2>
                <div class="flex items-center justify-center gap-[15px] text-[0.8rem] font-bold tracking-[0.1em] opacity-60 group-hover:opacity-100 transition-all">
                  CONTINUE READING
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </a>
            </div>
          ) : (
            <div class="text-center">
              <p class="opacity-50 mb-[30px] text-sm">You've finished the available chapters.</p>
              <div class="text-center">
                <a href={`/works/${work.id}`} class="inline-block px-[30px] py-3 bg-accent text-black font-bold text-[0.8rem] no-underline hover:scale-105 transition-all">BACK TO BOOK DETAIL</a>
              </div>
            </div>
          )}
          
          <div class="mt-[100px] flex justify-center text-[0.8rem] opacity-30">
            {prevChapter && <a href={`/works/${work.id}/${prevChapter.id}`} class="text-accent no-underline hover:underline">&larr; Previous Chapter</a>}
          </div>
        </section>
      </article>
    </main>
  </div>
</Layout>

<script>
  function handleScroll() {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    const bar = document.getElementById('scroll-bar');
    if (bar) bar.style.width = scrolled + "%";
  }

  window.addEventListener('scroll', handleScroll);
</script>
